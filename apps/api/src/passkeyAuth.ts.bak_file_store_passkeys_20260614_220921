import express from 'express';
import crypto from 'node:crypto';
import bcrypt from 'bcryptjs';
import {
  generateRegistrationOptions,
  verifyRegistrationResponse,
  generateAuthenticationOptions,
  verifyAuthenticationResponse,
} from '@simplewebauthn/server';

import { createToken } from './auth.js';
import { getWallet, loadDb, saveDb } from './db.js';

const RP_NAME = process.env.WEBAUTHN_RP_NAME || 'HipiPlay';
const RP_ID = process.env.WEBAUTHN_RP_ID || 'uribepro2.ddns.net';
const ORIGIN = process.env.WEBAUTHN_ORIGIN || 'https://uribepro2.ddns.net';
const TERMS_VERSION = process.env.HIPIPLAY_TERMS_VERSION || '2026-06-14';

export const passkeyAuthRouter = express.Router();

function nowIso() {
  return new Date().toISOString();
}

function cleanUsername(value: unknown) {
  return String(value || '').trim();
}

function toBase64Url(value: Uint8Array | Buffer | string) {
  if (typeof value === 'string') return value;
  return Buffer.from(value).toString('base64url');
}

function fromBase64Url(value: string) {
  return Buffer.from(value, 'base64url');
}

function ensureArrays(db: any) {
  if (!Array.isArray(db.users)) db.users = [];
  if (!Array.isArray(db.wallets)) db.wallets = [];
  if (!Array.isArray(db.passkeys)) db.passkeys = [];
  if (!Array.isArray(db.passkeyChallenges)) db.passkeyChallenges = [];
}

function removeOldChallenges(db: any) {
  const cutoff = Date.now() - (5 * 60 * 1000);
  db.passkeyChallenges = db.passkeyChallenges.filter((c: any) => {
    return new Date(c.createdAt || 0).getTime() > cutoff;
  });
}

function findUserByUsername(db: any, username: string) {
  return db.users.find((u: any) => String(u.username || '').toLowerCase() === username.toLowerCase());
}

function getUserPasskeys(db: any, user: any) {
  return db.passkeys.filter((p: any) => {
    return p.userId === user.id || String(p.username || '').toLowerCase() === String(user.username || '').toLowerCase();
  });
}

passkeyAuthRouter.post('/register/options', async (req, res) => {
  try {
    const username = cleanUsername(req.body?.username);
    const termsAccepted = Boolean(req.body?.termsAccepted);

    if (!username) {
      return res.status(400).json({ ok: false, error: 'Escribe tu usuario.' });
    }

    if (username.toLowerCase() === 'admin') {
      return res.status(400).json({ ok: false, error: 'Ese usuario no está disponible.' });
    }

    if (!termsAccepted) {
      return res.status(400).json({ ok: false, error: 'Debes aceptar los términos y condiciones de HipiPlay.' });
    }

    const db: any = loadDb();
    ensureArrays(db);
    removeOldChallenges(db);

    const existingUser = findUserByUsername(db, username);
    const existingPasskeys = existingUser ? getUserPasskeys(db, existingUser) : [];

    if (existingUser && existingPasskeys.length > 0) {
      return res.status(409).json({
        ok: false,
        error: 'Ese usuario ya existe. Usa iniciar sesión.'
      });
    }

    const webauthnUserID = existingUser?.id || `usr_${crypto.randomUUID()}`;

    const options: any = await generateRegistrationOptions({
      rpName: RP_NAME,
      rpID: RP_ID,
      userID: Buffer.from(webauthnUserID),
      userName: username,
      userDisplayName: username,
      attestationType: 'none',
      supportedAlgorithmIDs: [-7, -257],
      authenticatorSelection: {
        residentKey: 'preferred',
        userVerification: 'required'
      },
      excludeCredentials: existingPasskeys.map((p: any) => ({
        id: p.id || p.credentialId,
        transports: p.transports || []
      }))
    } as any);

    const challengeId = crypto.randomUUID();

    db.passkeyChallenges.push({
      id: challengeId,
      type: 'registration',
      username,
      webauthnUserID,
      challenge: options.challenge,
      termsAccepted: true,
      termsVersion: TERMS_VERSION,
      createdAt: nowIso()
    });

    saveDb(db);

    return res.json({
      status: 'OK',
      challengeId,
      options
    });
  } catch (error: any) {
    console.error('[PASSKEY REGISTER OPTIONS ERROR]', error);
    return res.status(500).json({
      ok: false,
      error: 'No se pudo iniciar el registro seguro.',
      detail: error?.message || String(error)
    });
  }
});

passkeyAuthRouter.post('/register/verify', async (req, res) => {
  try {
    const { challengeId, credential } = req.body || {};

    if (!challengeId || !credential) {
      return res.status(400).json({ ok: false, error: 'Registro incompleto.' });
    }

    const db: any = loadDb();
    ensureArrays(db);

    const challenge = db.passkeyChallenges.find((c: any) => c.id === challengeId && c.type === 'registration');

    if (!challenge) {
      return res.status(400).json({ ok: false, error: 'La sesión de registro expiró. Intenta de nuevo.' });
    }

    const verification: any = await verifyRegistrationResponse({
      response: credential,
      expectedChallenge: challenge.challenge,
      expectedOrigin: ORIGIN,
      expectedRPID: RP_ID,
      requireUserVerification: true
    } as any);

    if (!verification.verified || !verification.registrationInfo?.credential) {
      return res.status(400).json({ ok: false, error: 'No se pudo verificar la seguridad del dispositivo.' });
    }

    const registeredCredential = verification.registrationInfo.credential;
    const credentialId = registeredCredential.id;

    const existingUser = findUserByUsername(db, challenge.username);

    const user = existingUser || {
      id: challenge.webauthnUserID || `usr_${crypto.randomUUID()}`,
      username: challenge.username,
      passwordHash: bcrypt.hashSync(crypto.randomUUID(), 10),
      termsAccepted: true,
      termsVersion: challenge.termsVersion || TERMS_VERSION,
      termsAcceptedAt: nowIso(),
      createdAt: nowIso()
    };

    if (!existingUser) {
      db.users.push(user);
    } else {
      existingUser.termsAccepted = true;
      existingUser.termsVersion = challenge.termsVersion || TERMS_VERSION;
      existingUser.termsAcceptedAt = existingUser.termsAcceptedAt || nowIso();
    }

    const alreadyRegistered = db.passkeys.some((p: any) => (p.id || p.credentialId) === credentialId);

    if (!alreadyRegistered) {
      db.passkeys.push({
        id: credentialId,
        credentialId,
        userId: user.id,
        username: user.username,
        webauthnUserID: challenge.webauthnUserID,
        publicKey: toBase64Url(registeredCredential.publicKey),
        counter: registeredCredential.counter || 0,
        transports: credential?.response?.transports || registeredCredential.transports || [],
        deviceType: verification.registrationInfo.credentialDeviceType || null,
        backedUp: Boolean(verification.registrationInfo.credentialBackedUp),
        createdAt: nowIso(),
        lastUsedAt: null
      });
    }

    const wallet = getWallet(db, user.id);

    db.passkeyChallenges = db.passkeyChallenges.filter((c: any) => c.id !== challengeId);

    saveDb(db);

    return res.json({
      status: 'OK',
      token: createToken(user.id),
      user,
      wallet
    });
  } catch (error: any) {
    console.error('[PASSKEY REGISTER VERIFY ERROR]', error);
    return res.status(500).json({
      ok: false,
      error: 'No se pudo completar el registro seguro.',
      detail: error?.message || String(error)
    });
  }
});

passkeyAuthRouter.post('/login/options', async (req, res) => {
  try {
    const username = cleanUsername(req.body?.username);

    if (!username) {
      return res.status(400).json({ ok: false, error: 'Escribe tu usuario.' });
    }

    const db: any = loadDb();
    ensureArrays(db);
    removeOldChallenges(db);

    const user = findUserByUsername(db, username);

    if (!user) {
      return res.status(404).json({ ok: false, error: 'Ese usuario no existe. Crea la cuenta primero.' });
    }

    const userPasskeys = getUserPasskeys(db, user);

    if (userPasskeys.length === 0) {
      return res.status(409).json({
        ok: false,
        error: 'Este usuario no tiene huella registrada. Toca Crear cuenta para registrar este dispositivo.'
      });
    }

    const options: any = await generateAuthenticationOptions({
      rpID: RP_ID,
      userVerification: 'required',
      allowCredentials: userPasskeys.map((p: any) => ({
        id: p.id || p.credentialId,
        transports: p.transports || []
      }))
    } as any);

    const challengeId = crypto.randomUUID();

    db.passkeyChallenges.push({
      id: challengeId,
      type: 'authentication',
      username: user.username,
      userId: user.id,
      challenge: options.challenge,
      createdAt: nowIso()
    });

    saveDb(db);

    return res.json({
      status: 'OK',
      challengeId,
      options
    });
  } catch (error: any) {
    return res.status(500).json({
      ok: false,
      error: 'No se pudo iniciar sesión segura.',
      detail: error?.message || String(error)
    });
  }
});

passkeyAuthRouter.post('/login/verify', async (req, res) => {
  try {
    const { challengeId, credential, username } = req.body || {};

    if (!challengeId || !credential) {
      return res.status(400).json({ ok: false, error: 'Inicio de sesión incompleto.' });
    }

    const db: any = loadDb();
    ensureArrays(db);

    const challenge = db.passkeyChallenges.find((c: any) => c.id === challengeId && c.type === 'authentication');

    if (!challenge) {
      return res.status(400).json({ ok: false, error: 'La sesión de acceso expiró. Intenta de nuevo.' });
    }

    if (username && String(username).toLowerCase() !== String(challenge.username).toLowerCase()) {
      return res.status(403).json({ ok: false, error: 'La huella no corresponde a ese usuario.' });
    }

    const credentialId = credential?.id;

    const passkey = db.passkeys.find((p: any) => (p.id || p.credentialId) === credentialId);

    if (!passkey) {
      return res.status(404).json({ ok: false, error: 'Este dispositivo no está registrado con HipiPlay.' });
    }

    const user = db.users.find((u: any) => u.id === passkey.userId);

    if (!user) {
      return res.status(404).json({ ok: false, error: 'Usuario no encontrado.' });
    }

    const verification: any = await verifyAuthenticationResponse({
      response: credential,
      expectedChallenge: challenge.challenge,
      expectedOrigin: ORIGIN,
      expectedRPID: RP_ID,
      requireUserVerification: true,
      credential: {
        id: passkey.id || passkey.credentialId,
        publicKey: fromBase64Url(passkey.publicKey),
        counter: passkey.counter || 0,
        transports: passkey.transports || []
      }
    } as any);

    if (!verification.verified) {
      return res.status(401).json({ ok: false, error: 'No se pudo verificar tu huella.' });
    }

    passkey.counter = verification.authenticationInfo?.newCounter || passkey.counter || 0;
    passkey.lastUsedAt = nowIso();

    const wallet = getWallet(db, user.id);

    db.passkeyChallenges = db.passkeyChallenges.filter((c: any) => c.id !== challengeId);

    saveDb(db);

    return res.json({
      status: 'OK',
      token: createToken(user.id),
      user,
      wallet
    });
  } catch (error: any) {
    return res.status(500).json({
      ok: false,
      error: 'No se pudo completar el inicio de sesión.',
      detail: error?.message || String(error)
    });
  }
});