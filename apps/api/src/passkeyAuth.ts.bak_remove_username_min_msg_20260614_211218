import express from 'express';
import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';
import bcrypt from 'bcryptjs';
import {
  generateRegistrationOptions,
  verifyRegistrationResponse,
  generateAuthenticationOptions,
  verifyAuthenticationResponse,
} from '@simplewebauthn/server';
import { getWallet } from './db.js';
import { createToken } from './auth.js';

export const passkeyAuthRouter = express.Router();

const DATA_DIR = path.resolve(process.cwd(), 'data');
const DB_FILE = path.join(DATA_DIR, 'db.json');

const RP_NAME = process.env.WEBAUTHN_RP_NAME || 'HipiPlay';
const RP_ID = process.env.WEBAUTHN_RP_ID || 'uribepro2.ddns.net';
const ORIGIN = process.env.WEBAUTHN_ORIGIN || 'https://uribepro2.ddns.net';
const TERMS_VERSION = process.env.HIPIPLAY_TERMS_VERSION || '2026-06-14';

type AnyDb = {
  users: any[];
  wallets: any[];
  passkeys: any[];
  passkeyChallenges: any[];
  [key: string]: any;
};

function now() {
  return new Date().toISOString();
}

function cleanUsername(input: unknown) {
  return String(input || '').trim();
}

function readDbRaw(): AnyDb {
  if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });

  if (!fs.existsSync(DB_FILE)) {
    const empty = {
      users: [],
      wallets: [],
      events: [],
      bets: [],
      derbyRaces: [],
      derbyBets: [],
      tokenBurns: [],
      minuteOwnerPayouts: [],
      audits: [],
      referralLinks: [],
      referralPurchases: [],
      poolRounds: [],
      poolScores: [],
      walletMovements: [],
      passkeys: [],
      passkeyChallenges: []
    };

    fs.writeFileSync(DB_FILE, JSON.stringify(empty, null, 2), 'utf8');
  }

  const raw = fs.readFileSync(DB_FILE, 'utf8')
    .replace(/^\uFEFF/, '')
    .replace(/^\u200B/, '')
    .replace(/^\u0000/, '');

  const db = JSON.parse(raw) as AnyDb;

  db.users = Array.isArray(db.users) ? db.users : [];
  db.wallets = Array.isArray(db.wallets) ? db.wallets : [];
  db.passkeys = Array.isArray(db.passkeys) ? db.passkeys : [];
  db.passkeyChallenges = Array.isArray(db.passkeyChallenges) ? db.passkeyChallenges : [];

  return db;
}

function saveDbRaw(db: AnyDb) {
  if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });

  db.passkeys = Array.isArray(db.passkeys) ? db.passkeys : [];
  db.passkeyChallenges = Array.isArray(db.passkeyChallenges) ? db.passkeyChallenges : [];

  fs.writeFileSync(DB_FILE, JSON.stringify(db, null, 2), 'utf8');
}

function publicUser(user: any) {
  return {
    id: user.id,
    username: user.username
  };
}

function getClientDevice(req: express.Request) {
  return String(req.headers['user-agent'] || 'unknown');
}

function removeExpiredChallenges(db: AnyDb) {
  const current = Date.now();
  db.passkeyChallenges = (db.passkeyChallenges || []).filter((item: any) => {
    const expires = Date.parse(String(item.expiresAt || ''));
    return Number.isFinite(expires) && expires > current;
  });
}

passkeyAuthRouter.post('/register/options', async (req, res) => {
  try {
    const username = cleanUsername(req.body?.username);
    const termsAccepted = Boolean(req.body?.termsAccepted);

    if (username.length < 3) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'El nombre debe tener al menos 3 caracteres.'
      });
    }

    if (username.toLowerCase() === 'admin') {
      return res.status(400).json({
        status: 'ERROR',
        message: 'Ese usuario no está disponible.'
      });
    }

    if (!termsAccepted) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'Debes aceptar los términos y condiciones.'
      });
    }

    const db = readDbRaw();
    removeExpiredChallenges(db);

    const exists = db.users.some((user: any) =>
      String(user.username || '').toLowerCase() === username.toLowerCase()
    );

    if (exists) {
      return res.status(409).json({
        status: 'ERROR',
        message: 'Ese usuario ya existe.'
      });
    }

    const options = await generateRegistrationOptions({
      rpName: RP_NAME,
      rpID: RP_ID,
      userName: username,
      userDisplayName: username,
      attestationType: 'none',
      authenticatorSelection: {
        residentKey: 'required',
        userVerification: 'required',
        authenticatorAttachment: 'platform'
      },
      supportedAlgorithmIDs: [-7, -257],
    });

    const challengeId = crypto.randomUUID();

    db.passkeyChallenges.push({
      id: challengeId,
      type: 'registration',
      username,
      challenge: options.challenge,
      webauthnUserID: options.user.id,
      termsAccepted: true,
      termsVersion: TERMS_VERSION,
      createdAt: now(),
      expiresAt: new Date(Date.now() + 5 * 60 * 1000).toISOString(),
      deviceName: getClientDevice(req)
    });

    saveDbRaw(db);

    return res.json({
      status: 'OK',
      challengeId,
      options
    });
  } catch (err) {
    return res.status(500).json({
      status: 'ERROR',
      message: err instanceof Error ? err.message : 'No se pudo iniciar el registro con huella.'
    });
  }
});

passkeyAuthRouter.post('/register/verify', async (req, res) => {
  try {
    const challengeId = String(req.body?.challengeId || '');
    const credential = req.body?.credential;

    if (!challengeId || !credential) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'Faltan datos de validación.'
      });
    }

    const db = readDbRaw();
    removeExpiredChallenges(db);

    const challenge = db.passkeyChallenges.find((item: any) =>
      item.id === challengeId && item.type === 'registration'
    );

    if (!challenge) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'El reto de seguridad expiró. Intenta nuevamente.'
      });
    }

    const username = String(challenge.username || '').trim();

    const exists = db.users.some((user: any) =>
      String(user.username || '').toLowerCase() === username.toLowerCase()
    );

    if (exists) {
      return res.status(409).json({
        status: 'ERROR',
        message: 'Ese usuario ya existe.'
      });
    }

    const verification = await verifyRegistrationResponse({
      response: credential,
      expectedChallenge: challenge.challenge,
      expectedOrigin: ORIGIN,
      expectedRPID: RP_ID,
    });

    if (!verification.verified || !verification.registrationInfo) {
      return res.status(401).json({
        status: 'ERROR',
        message: 'No se pudo verificar la huella o seguridad del dispositivo.'
      });
    }

    const { credential: verifiedCredential, credentialDeviceType, credentialBackedUp } = verification.registrationInfo;

    const user = {
      id: `usr_${crypto.randomUUID().replace(/-/g, '')}`,
      username,
      passwordHash: bcrypt.hashSync(crypto.randomUUID(), 10),
      createdAt: now(),
      passkeyEnabled: true,
      termsAccepted: true,
      termsVersion: challenge.termsVersion || TERMS_VERSION,
      termsAcceptedAt: now()
    };

    db.users.push(user);

    const wallet = getWallet(db as any, user.id);

    db.passkeys.push({
      id: verifiedCredential.id,
      userId: user.id,
      username: user.username,
      webauthnUserID: challenge.webauthnUserID,
      publicKey: Buffer.from(verifiedCredential.publicKey).toString('base64url'),
      counter: verifiedCredential.counter,
      transports: verifiedCredential.transports || [],
      deviceType: credentialDeviceType,
      backedUp: credentialBackedUp,
      deviceName: challenge.deviceName || getClientDevice(req),
      createdAt: now(),
      lastUsedAt: null
    });

    db.passkeyChallenges = db.passkeyChallenges.filter((item: any) => item.id !== challengeId);

    saveDbRaw(db);

    const token = createToken(user.id);

    return res.json({
      status: 'OK',
      token,
      user: publicUser(user),
      wallet
    });
  } catch (err) {
    return res.status(400).json({
      status: 'ERROR',
      message: err instanceof Error ? err.message : 'No se pudo completar el registro con huella.'
    });
  }
});

passkeyAuthRouter.post('/login/options', async (_req, res) => {
  try {
    const db = readDbRaw();
    removeExpiredChallenges(db);

    const options = await generateAuthenticationOptions({
      rpID: RP_ID,
      userVerification: 'required'
    });

    const challengeId = crypto.randomUUID();

    db.passkeyChallenges.push({
      id: challengeId,
      type: 'authentication',
      challenge: options.challenge,
      createdAt: now(),
      expiresAt: new Date(Date.now() + 5 * 60 * 1000).toISOString()
    });

    saveDbRaw(db);

    return res.json({
      status: 'OK',
      challengeId,
      options
    });
  } catch (err) {
    return res.status(500).json({
      status: 'ERROR',
      message: err instanceof Error ? err.message : 'No se pudo iniciar el login con huella.'
    });
  }
});

passkeyAuthRouter.post('/login/verify', async (req, res) => {
  try {
    const challengeId = String(req.body?.challengeId || '');
    const credential = req.body?.credential;

    if (!challengeId || !credential) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'Faltan datos de validación.'
      });
    }

    const db = readDbRaw();
    removeExpiredChallenges(db);

    const challenge = db.passkeyChallenges.find((item: any) =>
      item.id === challengeId && item.type === 'authentication'
    );

    if (!challenge) {
      return res.status(400).json({
        status: 'ERROR',
        message: 'El reto de seguridad expiró. Intenta nuevamente.'
      });
    }

    const passkey = db.passkeys.find((item: any) => item.id === credential.id);

    if (!passkey) {
      return res.status(404).json({
        status: 'ERROR',
        message: 'Este dispositivo no está registrado en HipiPlay.'
      });
    }

    const verification = await verifyAuthenticationResponse({
      response: credential,
      expectedChallenge: challenge.challenge,
      expectedOrigin: ORIGIN,
      expectedRPID: RP_ID,
      credential: {
        id: passkey.id,
        publicKey: new Uint8Array(Buffer.from(passkey.publicKey, 'base64url')),
        counter: Number(passkey.counter || 0),
        transports: passkey.transports || []
      },
    });

    if (!verification.verified) {
      return res.status(401).json({
        status: 'ERROR',
        message: 'No se pudo verificar la seguridad del dispositivo.'
      });
    }

    const user = db.users.find((item: any) => item.id === passkey.userId);

    if (!user) {
      return res.status(404).json({
        status: 'ERROR',
        message: 'Usuario no encontrado.'
      });
    }

    passkey.counter = verification.authenticationInfo.newCounter;
    passkey.lastUsedAt = now();

    const wallet = getWallet(db as any, user.id);

    db.passkeyChallenges = db.passkeyChallenges.filter((item: any) => item.id !== challengeId);

    saveDbRaw(db);

    const token = createToken(user.id);

    return res.json({
      status: 'OK',
      token,
      user: publicUser(user),
      wallet
    });
  } catch (err) {
    return res.status(400).json({
      status: 'ERROR',
      message: err instanceof Error ? err.message : 'No se pudo completar el login con huella.'
    });
  }
});