  max-width: 820px;
}

.player-status {
  min-width: 180px;
  justify-content: center;
}

.live-dot.racing {
  background: #ff2d2d;
  box-shadow: 0 0 18px rgba(255, 45, 45, 0.85);
}

.bet-panel {
  display: grid;
  grid-template-columns: minmax(160px, 1fr) minmax(160px, 1fr) 2fr;
  gap: 14px;
  padding: 18px;
  border-radius: 24px;
  margin-bottom: 16px;
}

.bet-field label {
  display: block;
  margin-bottom: 8px;
  color: rgba(255,255,255,0.72);
  font-weight: 800;
}

.bet-field input,
.bet-field select {
  width: 100%;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 14px 16px;
  color: #fff;
  background: rgba(5, 12, 22, 0.82);
  outline: none;
  font-weight: 800;
}

.bet-button {
  align-self: end;
  min-height: 51px;
  font-weight: 900;
}

.race-tv {
  position: relative;
  padding: 18px;
  border-radius: 28px;
  overflow: hidden;
  border: 1px solid rgba(37, 211, 102, 0.18);
  background: radial-gradient(circle at 80% 0%, rgba(98, 255, 0, 0.12), transparent 28%), rgba(10, 21, 34, 0.94);
}

.race-tv-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
  color: #fff;
}

.race-tv-header > div:first-child {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.race-tv-header strong {
  font-size: 19px;
}

.race-tv-header small {
  color: rgba(255,255,255,0.72);
}

.live-badge {
  width: max-content;
  background: #d92d20;
  color: #fff;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1px;
  padding: 5px 10px;
  border-radius: 999px;
  box-shadow: 0 0 18px rgba(217, 45, 32, 0.5);
}

.race-clock {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: conic-gradient(#83ff00, #ffd21a, rgba(255,255,255,0.08));
  padding: 5px;
}

.race-clock span {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #0a1221;
  display: grid;
  place-items: center;
  color: #ffe66d;
  font-size: 19px;
  font-weight: 950;
}

.realistic-scene {
  position: relative;
  overflow: hidden;
  border-radius: 22px;
  background: linear-gradient(180deg, #0d2634 0%, #0b1f14 100%);
  border: 1px solid rgba(255,255,255,0.08);
}

.clean-grandstand {
  height: 44px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  text-align: center;
  color: rgba(255,255,255,0.72);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1.6px;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(0,0,0,0.16));
}

.realistic-track {
  position: relative;
  padding: 14px 42px 14px 84px;
  background:
    repeating-linear-gradient(180deg, rgba(255,255,255,0.055) 0px, rgba(255,255,255,0.055) 1px, transparent 1px, transparent 58px),
    linear-gradient(90deg, rgba(20, 79, 42, 0.95), rgba(58, 51, 18, 0.95));
}

.realistic-lane {
  position: relative;
  height: 58px;
  display: flex;
  align-items: center;
  border-bottom: 1px dashed rgba(255,255,255,0.13);
}

.realistic-lane.selected {
  background: linear-gradient(90deg, rgba(36, 207, 95, 0.23), transparent 45%);
}

.realistic-lane.winner-lane {
  background: linear-gradient(90deg, rgba(255, 216, 77, 0.18), transparent 52%);
}

.realistic-lane .lane-number {
  position: absolute;
  left: -66px;
  width: 52px;
  height: 31px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: #06110b;
  color: #ffd84d;
  font-weight: 950;
  font-size: 13px;
  z-index: 4;
}

.realistic-lane.selected .lane-number {
  background: #20ce5d;
  color: #fff;
}

.realistic-lane em {
  position: absolute;
  right: 8px;
  color: rgba(255,255,255,0.75);
  font-weight: 900;
}

.realistic-lane em.top3 {
  color: #ffd84d;
}

.lane-dirt {
  position: absolute;
  left: 0;
  right: 0;
  height: 15px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(83, 51, 15, 0.82), rgba(91, 73, 22, 0.4));
  opacity: .85;
}

.realistic-gate {
  position: absolute;
  left: 78px;
  top: 44px;
  bottom: 14px;
  width: 5px;
  background: repeating-linear-gradient(180deg, rgba(255,255,255,0.5) 0, rgba(255,255,255,0.5) 8px, transparent 8px, transparent 16px);
  z-index: 6;
}

.realistic-gate span,
.realistic-finish span {
  position: absolute;
  top: 0;
  writing-mode: vertical-rl;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: 2px;
}

.realistic-gate span {
  left: -16px;
  color: rgba(255,255,255,0.72);
}

.realistic-finish {
  position: absolute;
  right: 29px;
  top: 44px;
  bottom: 14px;
  width: 5px;
  background: repeating-linear-gradient(180deg, #fff 0, #fff 8px, #171717 8px, #171717 16px);
  z-index: 7;
  box-shadow: 0 0 22px rgba(255,255,255,0.42);
}

.realistic-finish span {
  right: -16px;
  color: #ffd84d;
}

.realistic-horse {
  width: 104px;
  height: 50px;
  position: absolute;
  left: var(--x);
  top: 50%;
  transform: translate(-50%, -50%);
  transition: left 0.18s linear;
  z-index: 5;
}

.realistic-horse.is-running {
  animation: horseBodyBounce 0.32s infinite ease-in-out;
  animation-delay: var(--delay);
}

.horse-shadow {
  position: absolute;
  left: 8px;
  bottom: -8px;
  width: 88px;
  height: 13px;
  border-radius: 50%;
  background: rgba(0,0,0,0.42);
  filter: blur(3px);
}

.horse-model {
  --horse-main: #7a421f;
  --horse-dark: #2a1208;
  --jockey-color: #ffd84d;
  position: relative;
  width: 96px;
  height: 48px;
}

.horse-color-1 { --horse-main: #7b3f1d; --horse-dark: #2b1409; --jockey-color: #ffd84d; }
.horse-color-2 { --horse-main: #9a6b3f; --horse-dark: #3b2412; --jockey-color: #4dd7ff; }
.horse-color-3 { --horse-main: #3f2a1d; --horse-dark: #120b07; --jockey-color: #ff5b5b; }
.horse-color-4 { --horse-main: #b47a45; --horse-dark: #4a2811; --jockey-color: #67ff8a; }
.horse-color-5 { --horse-main: #5d3926; --horse-dark: #1d0f09; --jockey-color: #c77dff; }
.horse-color-6 { --horse-main: #8f8a78; --horse-dark: #3a382e; --jockey-color: #ffffff; }

.horse-body {
  position: absolute;
  left: 23px;
  top: 16px;
  width: 54px;
  height: 22px;
  border-radius: 60% 45% 50% 55%;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  box-shadow: inset -8px -5px 0 rgba(0,0,0,0.22);
}

.horse-neck {
  position: absolute;
  left: 64px;
  top: 8px;
  width: 17px;
  height: 26px;
  border-radius: 12px 12px 5px 5px;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  transform: rotate(-28deg);
}

.horse-head {
  position: absolute;
  left: 76px;
  top: 5px;
  width: 24px;
  height: 17px;
  border-radius: 55% 45% 45% 55%;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  transform: rotate(-8deg);
}

.horse-ear {
  position: absolute;
  left: 82px;
  top: 0px;
  width: 7px;
  height: 11px;
  background: var(--horse-dark);
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.horse-mane {
  position: absolute;
  left: 64px;
  top: 7px;
  width: 8px;
  height: 24px;
  border-radius: 999px;
  background: #160b05;
  transform: rotate(-25deg);
}

.horse-tail {
  position: absolute;
  left: 8px;
  top: 17px;
  width: 28px;
  height: 8px;
  border-radius: 999px;
  background: linear-gradient(90deg, #160b05, var(--horse-dark));
  transform-origin: right center;
  animation: horseTailMove 0.45s infinite ease-in-out;
}

.horse-leg {
  position: absolute;
  top: 32px;
  width: 7px;
  height: 21px;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--horse-main), var(--horse-dark));
  transform-origin: top center;
}

.leg-front-a { left: 61px; }
.leg-front-b { left: 72px; }
.leg-back-a { left: 31px; }
.leg-back-b { left: 43px; }

.is-running .leg-front-a,
.is-running .leg-back-b { animation: legRunA 0.30s infinite ease-in-out; }
.is-running .leg-front-b,
.is-running .leg-back-a { animation: legRunB 0.30s infinite ease-in-out; }

.jockey-rider {
  position: absolute;
  left: 45px;
  top: 1px;
  width: 20px;
  height: 23px;
  border-radius: 10px 10px 6px 6px;
  background: linear-gradient(180deg, var(--jockey-color), #d98d00);
  border: 2px solid rgba(0,0,0,0.28);
  display: grid;
  place-items: center;
  color: #0c1710;
  font-size: 10px;
  font-weight: 950;
  transform: rotate(-8deg);
  z-index: 8;
}

.jockey-rider::before {
  content: "";
  position: absolute;
  top: -8px;
  width: 14px;
  height: 8px;
  border-radius: 8px 8px 3px 3px;
  background: #111827;
}

.race-dust {
  position: absolute;
  left: 10px;
  bottom: 3px;
  width: 10px;
  height: 6px;
  border-radius: 50%;
  background: rgba(215, 188, 117, 0.5);
  filter: blur(2px);
  animation: dustTrail 0.48s infinite ease-out;
}

.dust-two { left: 0; animation-delay: 0.18s; }

.race-final-board {
  margin-top: 16px;
  border-radius: 20px;
  padding: 18px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  border: 1px solid rgba(255,255,255,0.08);
}

.race-final-board.win {
  background: linear-gradient(135deg, rgba(37, 211, 102, 0.25), rgba(9, 34, 19, 0.65));
}

.race-final-board.lose {
  background: linear-gradient(135deg, rgba(255, 68, 68, 0.22), rgba(38, 12, 16, 0.65));
}

.result-pill {
  display: inline-block;
  margin-bottom: 8px;
  padding: 6px 12px;
  border-radius: 999px;
  font-weight: 950;
  background: #fff;
  color: #101828;
}

.race-final-board strong {
  display: block;
  color: #fff;
  font-size: 22px;
}

.race-final-board small,
.top3-board span {
  color: rgba(255,255,255,0.75);
}

.top3-board {
  text-align: right;
}

.top3-board strong {
  color: #ffd84d;
}

.market-player-panel {
  margin-top: 16px;
  padding: 18px;
  border-radius: 24px;
}

.market-player-head {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 14px;
}

.market-player-head strong {
  color: #fff;
}

.market-player-head small {
  display: block;
  color: rgba(255,255,255,0.62);
}

.market-player-head > span {
  color: #101828;
  background: #86efac;
  border-radius: 999px;
  padding: 8px 12px;
  font-weight: 900;
  height: max-content;
}

.clean-exposure-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10px;
}

.horse-exposure {
  padding: 14px;
  border-radius: 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  text-align: center;
}

.horse-exposure.least {
  border-color: rgba(255,216,77,0.55);
  background: rgba(255,216,77,0.12);
}

.horse-exposure span,
.horse-exposure small {
  display: block;
  color: rgba(255,255,255,0.68);
}

.horse-exposure strong {
  display: block;
  color: #fff;
  font-size: 18px;
  margin: 6px 0;
}

.clean-result {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.clean-actions {
  margin-top: 16px;
}

.clean-history .history-row span,
.clean-history .history-row strong {
  color: #fff;
}

@keyframes horseBodyBounce {
  0%, 100% { transform: translate(-50%, -50%) translateY(0); }
  50% { transform: translate(-50%, -50%) translateY(-4px); }
}

@keyframes horseTailMove {
  0%, 100% { transform: rotate(-18deg); }
  50% { transform: rotate(-3deg); }
}

@keyframes legRunA {
  0%, 100% { transform: rotate(25deg); }
  50% { transform: rotate(-30deg); }
}

@keyframes legRunB {
  0%, 100% { transform: rotate(-28deg); }
  50% { transform: rotate(30deg); }
}

@keyframes dustTrail {
  0% { opacity: 0.72; transform: translateX(0) scale(0.8); }
  100% { opacity: 0; transform: translateX(-30px) scale(1.9); }
}

@media (max-width: 980px) {
  .coin-dashboard,
  .clean-exposure-grid,
  .bet-panel {
    grid-template-columns: 1fr;
  }

  .race-final-board,
  .game-hero {
    flex-direction: column;
    align-items: stretch;
  }

  .top3-board {
    text-align: left;
  }
}

