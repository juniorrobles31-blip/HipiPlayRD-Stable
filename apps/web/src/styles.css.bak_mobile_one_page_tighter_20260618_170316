/* JUEGA123_REAL_RACE_60S_PATCH */
.derby-stadium.visual-race-active {
  border: 1px solid rgba(245, 197, 91, 0.35);
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38), inset 0 0 48px rgba(255, 197, 91, 0.08);
}

.broadcast-panel strong::before {
  content: "EN VIVO  ";
  display: inline-block;
  margin-right: 8px;
  padding: 3px 7px;
  border-radius: 999px;
  font-size: 10px;
  letter-spacing: 0.09em;
  background: rgba(255, 54, 54, 0.16);
  border: 1px solid rgba(255, 54, 54, 0.45);
  color: #ffb3b3;
}

.realistic-race-scene {
  position: relative;
  overflow: hidden;
  border-radius: 24px;
  background:
    radial-gradient(circle at 18% 10%, rgba(255,255,255,0.12), transparent 18%),
    linear-gradient(180deg, rgba(9, 43, 33, 0.92), rgba(5, 20, 16, 0.98));
}

.visual-race-active .realistic-race-scene::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.055), transparent);
  animation: cameraSweep 5.5s linear infinite;
}

.crowd-line {
  filter: drop-shadow(0 8px 18px rgba(0,0,0,0.4));
  animation: crowdPulse 1.6s ease-in-out infinite;
}

.realistic-track {
  position: relative;
  background:
    repeating-linear-gradient(180deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 58px),
    linear-gradient(180deg, #8a562f 0%, #6f3f21 100%);
  box-shadow: inset 0 18px 35px rgba(0,0,0,0.2), inset 0 -16px 30px rgba(0,0,0,0.25);
}

.realistic-lane {
  position: relative;
  overflow: hidden;
  min-height: 58px;
}

.realistic-lane::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 5px;
  height: 8px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
  opacity: 0.45;
}

.realistic-horse {
  position: absolute;
  left: var(--x);
  top: 50%;
  transform: translate(-50%, -50%);
  transition: left 960ms linear;
  z-index: 5;
  will-change: left, transform;
}

.visual-race-active .realistic-horse {
  animation: horseBodyMotion 0.34s ease-in-out infinite;
}

.realistic-horse .horse-sprite {
  display: inline-block;
  font-size: 34px;
  filter: drop-shadow(0 9px 8px rgba(0,0,0,0.38));
  animation: gallopFrame 0.28s steps(2, end) infinite;
}

.realistic-horse .horse-shadow {
  position: absolute;
  left: 8px;
  bottom: -6px;
  width: 46px;
  height: 10px;
  border-radius: 50%;
  background: rgba(0,0,0,0.33);
  filter: blur(3px);
}

.visual-race-active .lane-dirt::after {
  content: "";
  position: absolute;
  left: calc(var(--x) - 7%);
  top: 50%;
  width: 70px;
  height: 18px;
  transform: translateY(-50%);
  border-radius: 999px;
  background: radial-gradient(circle, rgba(210, 139, 74, 0.35), transparent 68%);
  filter: blur(4px);
  opacity: 0.85;
}

.visual-race-active .finish-line {
  box-shadow: 0 0 26px rgba(255, 255, 255, 0.18);
}

.visual-race-active.phase-revealed .winner-lane {
  background: linear-gradient(90deg, rgba(255, 214, 92, 0.18), transparent 75%);
}

@keyframes horseBodyMotion {
  0%, 100% { transform: translate(-50%, -50%) rotate(-1deg); }
  50% { transform: translate(-50%, calc(-50% - 3px)) rotate(1deg); }
}

@keyframes gallopFrame {
  0% { transform: scaleX(1) translateY(0); }
  50% { transform: scaleX(1.04) translateY(-2px); }
  100% { transform: scaleX(1) translateY(0); }
}

@keyframes cameraSweep {
  0% { transform: translateX(-100%); opacity: 0; }
  15% { opacity: 1; }
  100% { transform: translateX(100%); opacity: 0; }
}

@keyframes crowdPulse {
  0%, 100% { transform: translateY(0); opacity: 0.92; }
  50% { transform: translateY(-2px); opacity: 1; }
}

