}

.horse-exposure strong {
  display: block;
  color: #fff;
  font-size: 18px;
  margin: 6px 0;
}

.clean-result {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.clean-actions {
  margin-top: 16px;
}

.clean-history .history-row span,
.clean-history .history-row strong {
  color: #fff;
}

@keyframes horseBodyBounce {
  0%, 100% { transform: translate(-50%, -50%) translateY(0); }
  50% { transform: translate(-50%, -50%) translateY(-4px); }
}

@keyframes horseTailMove {
  0%, 100% { transform: rotate(-18deg); }
  50% { transform: rotate(-3deg); }
}

@keyframes legRunA {
  0%, 100% { transform: rotate(25deg); }
  50% { transform: rotate(-30deg); }
}

@keyframes legRunB {
  0%, 100% { transform: rotate(-28deg); }
  50% { transform: rotate(30deg); }
}

@keyframes dustTrail {
  0% { opacity: 0.72; transform: translateX(0) scale(0.8); }
  100% { opacity: 0; transform: translateX(-30px) scale(1.9); }
}

@media (max-width: 980px) {
  .coin-dashboard,
  .clean-exposure-grid,
  .bet-panel {
    grid-template-columns: 1fr;
  }

  .race-final-board,
  .game-hero {
    flex-direction: column;
    align-items: stretch;
  }

  .top3-board {
    text-align: left;
  }
}


