  --jockey-color: #ffd84d;
  position: relative;
  width: 96px;
  height: 48px;
}

.horse-color-1 { --horse-main: #7b3f1d; --horse-dark: #2b1409; --jockey-color: #ffd84d; }
.horse-color-2 { --horse-main: #9a6b3f; --horse-dark: #3b2412; --jockey-color: #4dd7ff; }
.horse-color-3 { --horse-main: #3f2a1d; --horse-dark: #120b07; --jockey-color: #ff5b5b; }
.horse-color-4 { --horse-main: #b47a45; --horse-dark: #4a2811; --jockey-color: #67ff8a; }
.horse-color-5 { --horse-main: #5d3926; --horse-dark: #1d0f09; --jockey-color: #c77dff; }
.horse-color-6 { --horse-main: #8f8a78; --horse-dark: #3a382e; --jockey-color: #ffffff; }

.horse-body {
  position: absolute;
  left: 23px;
  top: 16px;
  width: 54px;
  height: 22px;
  border-radius: 60% 45% 50% 55%;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  box-shadow: inset -8px -5px 0 rgba(0,0,0,0.22);
}

.horse-neck {
  position: absolute;
  left: 64px;
  top: 8px;
  width: 17px;
  height: 26px;
  border-radius: 12px 12px 5px 5px;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  transform: rotate(-28deg);
}

.horse-head {
  position: absolute;
  left: 76px;
  top: 5px;
  width: 24px;
  height: 17px;
  border-radius: 55% 45% 45% 55%;
  background: linear-gradient(135deg, var(--horse-main), var(--horse-dark));
  transform: rotate(-8deg);
}

.horse-ear {
  position: absolute;
  left: 82px;
  top: 0px;
  width: 7px;
  height: 11px;
  background: var(--horse-dark);
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.horse-mane {
  position: absolute;
  left: 64px;
  top: 7px;
  width: 8px;
  height: 24px;
  border-radius: 999px;
  background: #160b05;
  transform: rotate(-25deg);
}

.horse-tail {
  position: absolute;
  left: 8px;
  top: 17px;
  width: 28px;
  height: 8px;
  border-radius: 999px;
  background: linear-gradient(90deg, #160b05, var(--horse-dark));
  transform-origin: right center;
  animation: horseTailMove 0.45s infinite ease-in-out;
}

.horse-leg {
  position: absolute;
  top: 32px;
  width: 7px;
  height: 21px;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--horse-main), var(--horse-dark));
  transform-origin: top center;
}

.leg-front-a { left: 61px; }
.leg-front-b { left: 72px; }
.leg-back-a { left: 31px; }
.leg-back-b { left: 43px; }

.is-running .leg-front-a,
.is-running .leg-back-b { animation: legRunA 0.30s infinite ease-in-out; }
.is-running .leg-front-b,
.is-running .leg-back-a { animation: legRunB 0.30s infinite ease-in-out; }

.jockey-rider {
  position: absolute;
  left: 45px;
  top: 1px;
  width: 20px;
  height: 23px;
  border-radius: 10px 10px 6px 6px;
  background: linear-gradient(180deg, var(--jockey-color), #d98d00);
  border: 2px solid rgba(0,0,0,0.28);
  display: grid;
  place-items: center;
  color: #0c1710;
  font-size: 10px;
  font-weight: 950;
  transform: rotate(-8deg);
  z-index: 8;
}

.jockey-rider::before {
  content: "";
  position: absolute;
  top: -8px;
  width: 14px;
  height: 8px;
  border-radius: 8px 8px 3px 3px;
  background: #111827;
}

.race-dust {
  position: absolute;
  left: 10px;
  bottom: 3px;
  width: 10px;
  height: 6px;
  border-radius: 50%;
  background: rgba(215, 188, 117, 0.5);
