/* BEGIN_PATCH_HIPICA_BROADCAST_REAL */
.broadcast-race-tv {
  overflow: hidden;
  border-radius: 28px;
}

.broadcast-header {
  position: relative;
  z-index: 5;
}

.hipica-broadcast-stage {
  position: relative;
  height: min(72vw, 720px);
  min-height: 560px;
  margin-top: 16px;
  border-radius: 30px;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 5%, rgba(255,255,255,0.14), transparent 20%),
    linear-gradient(180deg, #10293b 0%, #132036 17%, #335021 18%, #55732c 26%, #8e5b2a 26%, #8b5726 74%, #466e28 74%, #214e1d 82%, #11253a 100%);
  border: 1px solid rgba(255,255,255,0.12);
  box-shadow: inset 0 0 110px rgba(0,0,0,0.35), 0 24px 80px rgba(0,0,0,0.3);
}

.grandstand-band {
  position: absolute;
  left: 0;
  right: 0;
  height: 46px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.1), rgba(0,0,0,0.15)),
    repeating-linear-gradient(90deg, rgba(255,255,255,0.22) 0 6px, rgba(0,0,0,0.0) 6px 18px);
  opacity: 0.7;
  z-index: 1;
}

.grandstand-top { top: 0; }
.grandstand-bottom { bottom: 0; opacity: 0.45; }

.rail {
  position: absolute;
  left: 6%;
  right: 5%;
  height: 4px;
  background: linear-gradient(90deg, rgba(255,255,255,0.78), rgba(255,255,255,0.35));
  box-shadow: 0 0 12px rgba(255,255,255,0.25);
  z-index: 2;
}
.rail-top { top: 18%; }
.rail-bottom { bottom: 18%; }

.track-label.overlay-label {
  position: absolute;
  color: rgba(255,255,255,0.72);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  z-index: 3;
  text-shadow: 0 2px 6px rgba(0,0,0,0.4);
}
.label-publico { top: 14.5%; left: 12%; }
.label-recta { top: 14.5%; left: 42%; }
.label-meta { top: 14.5%; right: 7.5%; }

.track-surface {
  position: absolute;
  inset: 18% 6% 18% 5%;
  border-radius: 26px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.08), transparent 14%),
    repeating-linear-gradient(90deg, rgba(139,89,43,0.1) 0 24px, rgba(102,62,28,0.16) 24px 48px),
    linear-gradient(180deg, rgba(166,112,57,0.14), rgba(74,45,19,0.25)),
    linear-gradient(180deg, #9e622e 0%, #7e4c21 100%);
  box-shadow: inset 0 22px 24px rgba(0,0,0,0.14), inset 0 -18px 18px rgba(0,0,0,0.18);
  z-index: 2;
}

.track-lane {
  position: absolute;
  left: 2%;
  right: 2%;
  height: 10.2%;
  transform: translateY(-50%);
  border-top: 1px dashed rgba(255,255,255,0.16);
  border-bottom: 1px dashed rgba(0,0,0,0.12);
}
.track-lane::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent 70%);
}
.lane-number {
  position: absolute;
  left: -16px;
  top: 50%;
  transform: translateY(-50%);
  width: 42px;
  height: 42px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  font-weight: 950;
  font-size: 13px;
  color: #f7f7f7;
  background: #08131a;
  border: 3px solid rgba(0,0,0,0.22);
  box-shadow: 0 8px 16px rgba(0,0,0,0.22);
}

.starting-gate-real {
  position: absolute;
  left: 6.5%;
  top: 18%;
  width: 74px;
  bottom: 18%;
  z-index: 20;
  pointer-events: none;
}
.starting-gate-real::before {
  content: "PARTIDOR";
  position: absolute;
  left: 50%;
  top: -22px;
  transform: translateX(-50%);
  font-size: 10px;
  letter-spacing: 1.2px;
  font-weight: 950;
  color: rgba(255,255,255,0.88);
}
.gate-stall {
  position: absolute;
  left: 0;
  width: 54px;
  height: 9.4%;
  transform: translateY(-50%);
  border: 3px solid rgba(183, 211, 221, 0.7);
  background: rgba(21, 35, 49, 0.55);
  box-shadow: inset 0 0 0 2px rgba(255,255,255,0.08);
}
.gate-stall::before,
.gate-stall::after {
  content: "";
  position: absolute;
  top: -3px;
  bottom: -3px;
  width: 12px;
  background: repeating-linear-gradient(90deg, rgba(227,240,247,0.7) 0 2px, transparent 2px 4px);
  border: 3px solid rgba(183, 211, 221, 0.7);
  transition: transform 0.7s ease, opacity 0.7s ease;
}
.gate-stall::before { left: -3px; transform-origin: left center; }
.gate-stall::after { right: -3px; transform-origin: right center; }
.starting-gate-real.gate-open .gate-stall::before { transform: rotateY(75deg); opacity: 0.35; }
.starting-gate-real.gate-open .gate-stall::after { transform: rotateY(-75deg); opacity: 0.35; }
.gate-stall span {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: #fff8d7;
  font-size: 12px;
  font-weight: 950;
}

.finish-line-real {
  position: absolute;
  right: 7.5%;
  top: 18%;
  bottom: 18%;
  width: 38px;
  z-index: 40;
}
.finish-post {
  position: absolute;
  left: 12px;
  top: 0;
  bottom: 0;
  width: 14px;
  background: repeating-linear-gradient(180deg, #fff 0 15px, #121212 15px 30px);
  border-radius: 999px;
  box-shadow: 0 0 20px rgba(255,255,255,0.45);
}
.finish-line-real::before,
.finish-line-real::after {
  content: "";
  position: absolute;
  left: -12px;
  right: -4px;
  height: 3px;
  background: rgba(255,255,255,0.88);
  box-shadow: 0 0 12px rgba(255,255,255,0.38);
}
.finish-line-real::before { top: 0; }
.finish-line-real::after { bottom: 0; }
.finish-line-real span {
  position: absolute;
  right: -6px;
  top: -26px;
  color: #ffe55b;
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 1.4px;
}

.broadcast-horse {
  position: absolute;
  width: 136px;
  height: 76px;
  transform: translate(-50%, -50%);
  transition: left 0.22s linear, top 0.22s linear;
  pointer-events: none;
  z-index: 30;
  filter: drop-shadow(0 10px 12px rgba(0,0,0,0.42));
}
.broadcast-horse .horse-svg {
  width: 136px;
  height: 76px;
  overflow: visible;
}
.broadcast-horse.is-running .horse-svg {
  animation: horseBodyRun 0.3s infinite ease-in-out;
  animation-delay: var(--delay);
}
.broadcast-horse.in-burst .horse-svg { animation-duration: 0.23s; }
.broadcast-horse.selected-horse {
  filter: drop-shadow(0 0 16px rgba(57, 255, 122, 0.76)) drop-shadow(0 10px 12px rgba(0,0,0,0.42));
}
.broadcast-horse.crossed-line {
  filter: drop-shadow(0 0 18px rgba(255, 221, 79, 0.85)) drop-shadow(0 10px 12px rgba(0,0,0,0.42));
}
.horse-lane-chip {
  position: absolute;
  left: 52%;
  top: -10px;
  transform: translateX(-50%);
  min-width: 34px;
  height: 24px;
  padding: 0 8px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: rgba(7, 16, 24, 0.95);
  color: #fff;
  font-size: 12px;
  font-weight: 950;
  border: 2px solid rgba(255,255,255,0.18);
}
.track-dust {
  position: absolute;
  left: -6px;
  top: 50px;
  width: 12px;
  height: 8px;
  border-radius: 50%;
  background: rgba(220, 170, 102, 0.56);
  filter: blur(2px);
  animation: ovalDust 0.55s infinite ease-out;
}
.track-dust.dust-b { left: -16px; top: 57px; animation-delay: 0.16s; }
.motion-streak {
  position: absolute;
  left: -30px;
  top: 28px;
  width: 44px;
  height: 3px;
  border-radius: 999px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8));
  animation: ovalSpeed 0.26s infinite linear;
}
.motion-streak.streak-b { top: 42px; width: 32px; animation-delay: 0.1s; }
.finish-ribbon {
  position: absolute;
  right: -12px;
  top: -14px;
  padding: 6px 9px;
  border-radius: 999px;
  background: rgba(255, 221, 79, 0.96);
  color: #09150f;
  font-size: 11px;
  font-weight: 950;
  box-shadow: 0 0 18px rgba(255,221,79,0.6);
}

.mini-oval-panel {
  position: absolute;
  right: 4.5%;
  top: 6%;
  width: 190px;
  padding: 12px 12px 10px;
  border-radius: 22px;
  background: rgba(5, 14, 20, 0.72);
  border: 1px solid rgba(255,255,255,0.1);
  z-index: 35;
  box-shadow: 0 14px 35px rgba(0,0,0,0.28);
}
.mini-oval-title {
  color: #f1f5f9;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 1px;
  margin-bottom: 8px;
  text-transform: uppercase;
}
.mini-oval-map {
  position: relative;
  height: 118px;
}
.mini-oval-map svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.mini-oval-outer { fill: rgba(61, 119, 52, 0.78); }
.mini-oval-inner { fill: none; stroke: rgba(205,185,135,0.92); stroke-width: 7; stroke-dasharray: 10 6; }
.mini-oval-field { fill: rgba(39, 103, 49, 0.9); }
.mini-map-marker {
  position: absolute;
  width: 18px;
  height: 18px;
  transform: translate(-50%, -50%);
  border-radius: 999px;
  display: grid;
  place-items: center;
  color: #0b1218;
  font-size: 9px;
  font-weight: 950;
  border: 2px solid rgba(255,255,255,0.24);
  z-index: 2;
  box-shadow: 0 4px 10px rgba(0,0,0,0.32);
}
.mini-map-marker.selected { box-shadow: 0 0 0 2px rgba(57,255,122,0.5), 0 4px 10px rgba(0,0,0,0.32); }
.mini-map-marker.top3 { transform: translate(-50%, -50%) scale(1.08); }

.inside-scoreboard {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 280px;
  max-width: 360px;
  padding: 20px 24px;
  border-radius: 24px;
  background: rgba(5, 16, 12, 0.78);
  border: 1px solid rgba(255,255,255,0.1);
  text-align: center;
  color: rgba(255,255,255,0.88);
  z-index: 10;
  box-shadow: 0 18px 50px rgba(0,0,0,0.35);
}
.inside-scoreboard strong {
  display: block;
  color: #ffdf4f;
  font-size: 13px;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.inside-scoreboard span {
  display: block;
  margin-top: 6px;
  font-size: 22px;
  font-weight: 950;
}
.inside-scoreboard small {
  display: block;
  margin-top: 7px;
  color: rgba(255,255,255,0.64);
  line-height: 1.35;
}

.broadcast-commentary {
  margin-top: 14px;
  padding: 14px 16px;
  border-radius: 18px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.86);
  line-height: 1.5;
}
.broadcast-commentary strong { color: #ffdf4f; margin-right: 6px; }

@media (max-width: 980px) {
  .hipica-broadcast-stage { min-height: 520px; height: 78vw; }
  .broadcast-horse { width: 112px; height: 62px; }
  .broadcast-horse .horse-svg { width: 112px; height: 62px; }
  .mini-oval-panel { width: 150px; top: 5.5%; }
  .inside-scoreboard { min-width: 220px; max-width: 270px; padding: 16px; }
  .track-label.overlay-label { font-size: 10px; }
}
