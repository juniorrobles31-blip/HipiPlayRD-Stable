import resultTop3Bg from '../../assets/results-top3-bg.png';

type ServerWinner =
  | number
  | string
  | {
      id?: number | string;
      horseId?: number | string;
      horse?: number | string;
      number?: number | string;
      selectedHorse?: number | string;
    };

type ServerRaceResultPanelProps = {
  winners: ServerWinner[];
  selectedHorse?: number;
  betAmount?: number;
  secondsLeft?: number;
  serverPlayerResult?: any;
};

function normalizeWinner(winner: ServerWinner): number | null {
  if (typeof winner === 'number') return winner;

  if (typeof winner === 'string') {
    const parsed = Number(winner);
    return Number.isFinite(parsed) ? parsed : null;
  }

  if (winner && typeof winner === 'object') {
    const value =
      winner.id ??
      winner.horseId ??
      winner.horse ??
      winner.number ??
      winner.selectedHorse;

    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : null;
  }

  return null;
}

function formatMoney(value: number): string {
  return new Intl.NumberFormat('es-DO', {
    maximumFractionDigits: 0
  }).format(Math.max(0, Math.floor(Number(value) || 0)));
}

export function ServerRaceResultPanel({
  winners,
  selectedHorse,
  betAmount = 0,
  secondsLeft = 0,
  serverPlayerResult
}: ServerRaceResultPanelProps) {
  const officialWinners = (Array.isArray(winners) ? winners : [])
    .map(normalizeWinner)
    .filter((winner): winner is number => Number.isFinite(Number(winner)) && Number(winner) >= 1 && Number(winner) <= 6)
    .slice(0, 3);

  const selected = Number(selectedHorse || 0);
  const hasTicket = Number.isFinite(selected) && selected >= 1 && selected <= 6 && Number(betAmount) > 0;

  const position = hasTicket ? officialWinners.indexOf(selected) : -1;
  const won = position >= 0;

  const multiplier =
    position === 0 ? 2 :
    position === 1 ? 1.5 :
    position === 2 ? 1.5 :
    0;

  const calculatedPayout = won ? Math.floor(Number(betAmount) * multiplier) : 0;

  const payout =
    Number(serverPlayerResult?.payout ?? serverPlayerResult?.winAmount ?? calculatedPayout) || 0;

  const resultClass = !hasTicket ? 'no-ticket' : won ? 'win' : 'loss';

  const podium = [
    { place: '1.º', horse: officialWinners[0] ?? null, className: 'result-marker result-marker-top' },
    { place: '2.º', horse: officialWinners[1] ?? null, className: 'result-marker result-marker-middle' },
    { place: '3.º', horse: officialWinners[2] ?? null, className: 'result-marker result-marker-bottom' }
  ];

  return (
    <section className="server-results-fullscreen-image">
      <div className="server-results-stage-image">
        <img
          src={resultTop3Bg}
          alt="Resultado oficial Top 3"
          className="server-results-bg-image"
        />

        <div className="server-results-image-overlay">
          <div className="server-results-title-pill">
            Resultado oficial
          </div>

          {podium.map((item) => (
            <div key={item.place} className={item.className}>
              <span>{item.place}</span>
              <strong>{item.horse ? `#${item.horse}` : '-'}</strong>
            </div>
          ))}

          <div className={`server-results-summary-pill ${resultClass}`}>
            <small>Resultado de monedas</small>
            <strong>{formatMoney(payout)}</strong>

            {!hasTicket ? (
              <span>No generaste boleto en esta carrera.</span>
            ) : won ? (
              <span>Ganaste con el caballo #{selected}.</span>
            ) : (
              <span>Tu caballo #{selected} no quedó en el Top 3.</span>
            )}
          </div>

          <div className="server-results-next-round-pill">
            Nueva ronda en {Math.max(0, Number(secondsLeft || 0))}s
          </div>
        </div>
      </div>
    </section>
  );
}