type CyclePhase = 'betting' | 'running';

type CycleInfo = {
  cycleIndex: number;
  raceId: string;
  raceCode: string;
  seed: string;
  phase: CyclePhase;
  phaseElapsed: number;
  phaseRemaining: number;
  bettingProgress: number;
  raceProgress: number;
};

type UserRaceBet = {
