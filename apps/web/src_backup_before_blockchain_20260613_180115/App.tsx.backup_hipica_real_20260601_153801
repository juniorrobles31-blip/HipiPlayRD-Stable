function RaceTrack({ cycle, resultOrder, selectedHorse, lastResult }: { cycle: CycleInfo; resultOrder: number[]; selectedHorse?: number; lastResult?: RaceResult | null }) {
  const running = cycle.phase === 'running';
  const progress = running ? cycle.raceProgress : 0;
  const secondsLeft = Math.ceil(cycle.phaseRemaining / 1000);
  const top3 = resultOrder.slice(0, 3);
  const finalSprint = running && progress >= 0.78;
  const photoFinish = running && progress >= 0.94;

  const smooth = (n: number) => {
    const t = clamp(n, 0, 1);
    return t * t * (3 - 2 * t);
  };

  function horseX(horse: number) {
    const rankIndex = resultOrder.indexOf(horse);
    const rank = rankIndex >= 0 ? rankIndex + 1 : horse;

    // Durante los primeros 45 segundos nadie debe parecer ganador seguro.
    // Se ven cambios de ritmo, pequeños adelantamientos y grupo compacto.
    const packProgress = smooth(Math.min(progress / 0.78, 1));
    const base = 7 + packProgress * 72;
    const rhythmA = Math.sin((cycle.phaseElapsed / (520 + horse * 31)) + horse * 1.7) * 2.8;
    const rhythmB = Math.cos((cycle.phaseElapsed / (930 + horse * 43)) + rank * 2.1) * 1.9;
    const falseLead = Math.sin((progress * Math.PI * 5) + horse) * 3.4;
    const laneVariation = (hashString(`${cycle.seed}:lane:${horse}`) % 700) / 1000;
    const packX = base + rhythmA + rhythmB + falseLead + laneVariation;

    // Últimos 13 segundos: se activa el remate real. Solo ahí los Top 3 cruzan la meta.
    const sprint = smooth((progress - 0.78) / 0.22);
    const finishX = rank === 1
      ? 97.6
      : rank === 2
        ? 95.6
        : rank === 3
          ? 93.7
          : 89.8 - ((rank - 4) * 2.2);

    const x = progress < 0.78
      ? packX
      : packX + (finishX - packX) * sprint;

    return clamp(x, 5, 98.4);
  }

  return <section className={`race-tv glass pro-race-tv ${running ? 'race-running' : 'race-betting'} ${finalSprint ? 'final-sprint' : ''} ${photoFinish ? 'photo-finish-mode' : ''}`}>
    <div className="race-tv-header pro-race-header">
      <div>
        <span className={running ? 'live-badge' : 'betting-badge'}>{running ? 'EN VIVO' : 'APUESTAS'}</span>
        <strong>{running ? 'Carrera en vivo - 60 segundos' : 'Ventana de apuestas - 60 segundos'}</strong>
        <small>{running ? `Tiempo restante de carrera: ${secondsLeft}s` : `Cierre de apuestas en: ${secondsLeft}s`}</small>
      </div>
      <div className="race-clock">
        <span>{secondsLeft}</span>
      </div>
    </div>

    <div className="race-scene realistic-scene pro-track-scene">
      <div className="track-skyline">
        <span>GRADAS</span>
        <span>PUBLICO</span>
        <span>CURVA FINAL</span>
        <span>META</span>
      </div>
      <div className="track-rail top-rail"></div>
      <div className="track-rail bottom-rail"></div>
      <div className="starting-gate realistic-gate"><span>PARTIDA</span></div>
      <div className="finish-line realistic-finish pro-finish"><span>META</span></div>
      {photoFinish && <div className="finish-flash">FOTO FINISH</div>}

      <div className="race-track derby-track cinematic realistic-track pro-race-track">
        {HORSES.map(horse => {
          const rankIndex = resultOrder.indexOf(horse);
          const rank = rankIndex >= 0 ? rankIndex + 1 : horse;
          const isWinner = top3.includes(horse);
          const x = running ? horseX(horse) : 6 + horse * 0.72;
          const crossed = running && progress > 0.965 && isWinner;

          return <RaceHorse
            key={horse}
            horse={horse}
            x={x}
            running={running}
            selected={selectedHorse === horse}
            winnerLane={photoFinish && isWinner}
            sprinting={finalSprint}
            crossed={crossed}
            rank={!running && lastResult ? rank : undefined}
          />;
        })}
      </div>
    </div>

    {running && <div className="race-commentary pro-commentary">
      <strong>{photoFinish ? 'Llegada a la meta:' : finalSprint ? 'Últimos metros:' : 'Narración en vivo:'}</strong>
      {photoFinish
        ? ' los caballos cruzan la línea. El resultado oficial se revela al terminar el minuto.'
        : finalSprint
          ? ' entran en la recta final y empiezan los remates.'
          : ' el grupo corre compacto; nada está decidido todavía.'}
    </div>}

    {!running && lastResult && <div className={`race-final-board pro-final-board ${lastResult.won ? 'win' : lastResult.won === false ? 'lose' : 'neutral'}`}>
      <div>
        <span className="result-pill">RESULTADO OFICIAL</span>
        <strong>{lastResult.raceCode}</strong>
        <small>{lastResult.won === undefined ? 'Resultado de la carrera anterior.' : lastResult.won ? 'Tu caballo entró en el Top 3.' : 'Tu caballo quedó fuera del Top 3.'}</small>
      </div>
      <div className="podium-result">
        {lastResult.resultOrder.slice(0, 3).map((h, i) => <div key={h} className={`podium-place p${i + 1}`}>
          <span>{i + 1}o</span>
          <strong>#{h}</strong>
        </div>)}
      </div>
      <div className="win-lose-text">{lastResult.won === undefined ? 'Carrera finalizada' : lastResult.won ? 'GANASTE' : 'PERDISTE'}</div>
    </div>}
  </section>;
}

function DerbyGame({ user, wallet, refreshLocal }: { user: User; wallet: LocalWalletState | null; refreshLocal: () => Promise<void> }) {
  const [now, setNow] = useState(Date.now());
  const [amount, setAmount] = useState(100);
  const [horse, setHorse] = useState(1);
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [message, setMessage] = useState('');
  const [loading, setLoading] = useState(false);
  const [userBetsByRace, setUserBetsByRace] = useState<Record<string, UserRaceBet>>({});
  const [lastResult, setLastResult] = useState<RaceResult | null>(null);
  const resolvedRacesRef = useRef<Set<string>>(new Set());

  const cycle = useMemo(() => getCycleInfo(now), [now]);

  async function loadLocalBets() {
    const all = await localDerbyHistory(user.id);
    setBets(all);
  }

  async function syncNowQuietly() {
    try {
      await syncPendingQueue(20);
    } catch {
      // La sincronización no debe interrumpir la carrera.
    } finally {
      await refreshLocal();
    }
  }

  useEffect(() => {
    loadLocalBets().catch(() => null);
    const interval = setInterval(() => setNow(Date.now()), 250);
    const historyInterval = setInterval(() => loadLocalBets().catch(() => null), 3000);
    return () => {
      clearInterval(interval);
      clearInterval(historyInterval);
    };
  }, [user.id]);

  function userBetForRace(raceId: string, raceCode: string): UserRaceBet | null {
    if (userBetsByRace[raceId]) return userBetsByRace[raceId];
    const pending = bets.find(b => b.raceId === raceId && b.status === 'pending');
    if (!pending) return null;
    return {
      raceId,
      raceCode,
      betId: pending.id,
      selectedHorse: pending.selectedHorse,
      amount: pending.amount,
    };
  }

  function exposureForRace(race: CycleInfo, userBet: UserRaceBet | null, progressOverride?: number) {
    const publicExposure = buildPublicMarket(race, progressOverride ?? race.bettingProgress);
    return addUserBetToExposure(publicExposure, userBet, user.id);
  }

  const currentUserBet = userBetForRace(cycle.raceId, cycle.raceCode);
  const currentExposure = exposureForRace(cycle, currentUserBet, cycle.phase === 'running' ? 1 : cycle.bettingProgress);
  // Resultado interno: se calcula con la exposición del mercado, pero el jugador solo ve el resultado final.
  const resultOrder = buildResultOrderFromExposure(currentExposure, cycle.seed);
  const pendingCount = bets.filter(b => b.status === 'pending').length;
  const lastBet = bets[0];
  const bettingOpen = cycle.phase === 'betting' && !currentUserBet && getMarketStatus(currentExposure).canAcceptBet;

  useEffect(() => {
    if (cycle.phase !== 'betting') return;
    const previousIndex = cycle.cycleIndex - 1;
    if (previousIndex < 0) return;

    const previousRace = getCycleInfo(now, previousIndex);
    if (resolvedRacesRef.current.has(previousRace.raceId)) return;

    const previousUserBet = userBetForRace(previousRace.raceId, previousRace.raceCode);
    const previousExposure = exposureForRace(previousRace, previousUserBet, 1);
    const previousOrder = buildResultOrderFromExposure(previousExposure, previousRace.seed);
    const top3 = previousOrder.slice(0, 3);
    const won = previousUserBet ? top3.includes(previousUserBet.selectedHorse) : undefined;

    resolvedRacesRef.current.add(previousRace.raceId);
    setLastResult({
      raceId: previousRace.raceId,
      raceCode: previousRace.raceCode,
      resultOrder: previousOrder,
      exposure: previousExposure,
      selectedHorse: previousUserBet?.selectedHorse,
      amount: previousUserBet?.amount,
      won,
      resolvedAt: Date.now(),
    });

    if (previousUserBet) {
      resolvePendingLocalBets(user.id, previousRace.raceId, previousRace.raceCode, previousOrder)
        .then(async () => {
          setMessage(won
            ? `GANASTE. Top 3 ganador: ${top3.map(h => `#${h}`).join(', ')}.`
            : `PERDISTE. Top 3 ganador: ${top3.map(h => `#${h}`).join(', ')}.`
          );
          await refreshLocal();
          await loadLocalBets();
          await syncNowQuietly();
        })
        .catch(err => setMessage(normalizeError(err)));
    }
  }, [cycle.cycleIndex, cycle.phase]);

  async function bet() {
    if (!bettingOpen) {
      setMessage(cycle.phase === 'running'
        ? 'La carrera está corriendo. Las apuestas abren en la próxima ronda.'
        : 'Ya tienes un boleto en esta carrera o el mercado está cerrado.'
      );
      return;
    }

    const safeAmount = Math.floor(Number(amount || 0));
    if (!Number.isFinite(safeAmount) || safeAmount <= 0) {
      setMessage('Ingresa una cantidad válida de monedas.');
      return;
    }

    if ((wallet?.demoBalance || 0) < safeAmount) {
      setMessage('Monedas insuficientes para realizar esta apuesta.');
      return;
    }

    setLoading(true);
    setMessage('');
    try {
      const res = await placeLocalDerbyBet({
        userId: user.id,
        raceId: cycle.raceId,
        raceCode: cycle.raceCode,
        mode: 'demo',
        horse,
        amount: safeAmount,
      });

      const placedBet = {
        raceId: cycle.raceId,
        raceCode: cycle.raceCode,
        betId: res.bet.id,
        selectedHorse: horse,
        amount: safeAmount,
      };

      setUserBetsByRace(prev => ({ ...prev, [cycle.raceId]: placedBet }));
      setMessage(`Boleto generado: ${res.bet.id}. Espera el cierre de apuestas; la carrera correrá 60 segundos.`);
      await refreshLocal();
      await loadLocalBets();
      syncNowQuietly();
    } catch (err) {
      setMessage(normalizeError(err));
    } finally {
      setLoading(false);
    }
  }

  return <div className="player-screen">
    <PlayerSummary wallet={wallet} pendingCount={pendingCount} lastBet={lastBet} lastResult={lastResult} />

    <section className="game-hero glass cycle-hero">
      <div className="game-title-block">
        <div className="big-icon text-icon">DERBY</div>
        <div>
          <h2>Derby Minute</h2>
          <p>60 segundos para apostar, 60 segundos de carrera. El resultado oficial se revela al finalizar cada carrera.</p>
        </div>
      </div>
      <div className="cycle-status">
        <span className={cycle.phase === 'running' ? 'live-dot racing' : 'live-dot'}></span>
        <strong>{cycle.phase === 'betting' ? 'Apuestas abiertas' : 'Carrera en vivo'}</strong>
        <small>{cycle.raceCode}</small>
      </div>
    </section>

    <div className="cycle-steps glass">
      <div className={cycle.phase === 'betting' ? 'step active' : 'step done'}><span>01</span><strong>Apuestas</strong><small>60 segundos</small></div>
      <div className="step-line"></div>
      <div className={cycle.phase === 'running' ? 'step active' : 'step'}><span>02</span><strong>Carrera</strong><small>60 segundos</small></div>
      <div className="step-line"></div>
      <div className={lastResult ? 'step done' : 'step'}><span>03</span><strong>Resultado</strong><small>Top 3</small></div>
    </div>

    <div className="bet-panel glass">
      <div className="bet-field">
        <label>Cantidad de monedas</label>
        <input type="number" min={1} value={amount} onChange={e => setAmount(Number(e.target.value))} disabled={!bettingOpen || loading} />
      </div>
      <div className="bet-field">
        <label>Caballo</label>
        <select value={horse} onChange={e => setHorse(Number(e.target.value))} disabled={!bettingOpen || loading}>
          {HORSES.map(n => <option key={n} value={n}>Caballo #{n}</option>)}
        </select>
      </div>
      <button className="primary bet-button" onClick={bet} disabled={!bettingOpen || loading}>
        {loading ? 'Generando boleto...' : currentUserBet ? 'Boleto generado' : cycle.phase === 'running' ? 'Apuestas cerradas' : `Apostar ${coins(amount)} monedas al #${horse}`}
      </button>
    </div>

    <RaceTrack cycle={cycle} resultOrder={resultOrder} selectedHorse={currentUserBet?.selectedHorse || horse} lastResult={lastResult} />
    {currentUserBet && cycle.phase === 'betting' && <div className="result-card neutral"><strong>Boleto activo:</strong> Caballo #{currentUserBet.selectedHorse} - {coins(currentUserBet.amount)} monedas. La carrera inicia cuando cierre el contador.</div>}

    {message && <div className={`result-card ${message.startsWith('GANASTE') ? 'win' : message.startsWith('PERDISTE') ? 'lose' : 'neutral'}`}>
      <strong>{message}</strong>
    </div>}
  </div>;
}

function HistoryPanel({ userId }: { userId: string }) {
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [movements, setMovements] = useState<LocalLedgerMovement[]>([]);

  async function load() {
    setBets(await localDerbyHistory(userId));
    const all = await dbGetAll<LocalLedgerMovement>('ledger_movements');
    setMovements(all.filter(m => m.userId === userId).sort((a, b) => b.createdAt.localeCompare(a.createdAt)));
  }

  useEffect(() => {
    load();
    const t = setInterval(load, 3000);
    return () => clearInterval(t);
  }, [userId]);

  return <section className="glass history-card clean-history">
    <h2><History /> Historial de jugadas</h2>
    {bets.length === 0 ? <p>No hay boletos registrados.</p> : bets.map(b => <div className="history-row" key={b.id}>
      <strong>{b.raceCode}</strong>
      <span>Caballo #{b.selectedHorse}</span>
      <span>{coins(b.amount)} monedas</span>
      <span className={b.status === 'won' ? 'pos' : b.status === 'lost' ? 'neg' : ''}>{b.status === 'won' ? 'Ganó' : b.status === 'lost' ? 'Perdió' : 'Pendiente'}</span>
      <small>{new Date(b.createdAt).toLocaleString()}</small>
    </div>)}
    {movements.length > 0 && <small className="muted">Jugadas registradas: {movements.length}</small>}
  </section>;
}

export function App() {
  const [user, setUser] = useState<User | null>(null);
  const [localWallet, setLocalWallet] = useState<LocalWalletState | null>(null);
  const [tab, setTab] = useState<Tab>('games');
  const [loading, setLoading] = useState(true);

  async function refreshLocal(userId = user?.id) {
    if (!userId) return;
    const wallet = await getLocalWallet(userId);
    setLocalWallet(wallet);
  }

  async function bootstrap(u: User, w: Wallet) {
    setUser(u);
    const local = await initLocalWallet(u.id, {
      demoBalance: w.demoBalance,
      realBalance: w.realBalance,
      giftLocked: w.giftLocked,
    });
    setLocalWallet(local);
  }

  useEffect(() => {
    api.me().then(res => bootstrap(res.user, res.wallet)).catch(() => null).finally(() => setLoading(false));
  }, []);

  if (loading) return <div className="loading"><Sparkles className="spin" /> Cargando juego...</div>;
  if (!user) return <Login onLogin={(u, w) => { bootstrap(u, w); }} />;

  return <div className="app-shell clean-player-shell">
    <header className="topbar glass clean-topbar">
      <div className="brand"><span className="brand-derby">DERBY</span><div><strong>Juega123 Derby</strong><small>Monedas + carreras automáticas</small></div></div>
      <nav>
        <button className={tab === 'games' ? 'active' : ''} onClick={() => setTab('games')}><Trophy size={17}/> Derby</button>
        <button className={tab === 'history' ? 'active' : ''} onClick={() => setTab('history')}><History size={17}/> Historial</button>
      </nav>
      <button className="ghost" onClick={() => { logout(); location.reload(); }}><LogOut size={18}/> Salir</button>
    </header>

    <main className="clean-main">
      {tab === 'games' && <DerbyGame user={user} wallet={localWallet} refreshLocal={() => refreshLocal(user.id)} />}
      {tab === 'history' && <HistoryPanel userId={user.id} />}
    </main>
  </div>;
}
