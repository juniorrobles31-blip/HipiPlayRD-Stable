export function App() {
  const [user, setUser] = useState<User | null>(null);
  const [serverWallet, setServerWallet] = useState<Wallet | null>(null);
  const [localWallet, setLocalWallet] = useState<LocalWalletState | null>(null);
  const [syncCount, setSyncCount] = useState(0);
  const [online, setOnline] = useState(navigator.onLine);
  const [tab, setTab] = useState<Tab>('games');
  const [loading, setLoading] = useState(true);

  async function refreshLocal(userId = user?.id) {
    if (!userId) return;
    const wallet = await getLocalWallet(userId);
    setLocalWallet(wallet);
    setSyncCount((await pendingSyncItems()).length);
  }

  async function bootstrap(u: User, w: Wallet) {
    setUser(u); setServerWallet(w);
    const local = await initLocalWallet(u.id, { demoBalance: w.demoBalance, realBalance: w.realBalance, giftLocked: w.giftLocked });
    setLocalWallet(local);
    setSyncCount((await pendingSyncItems()).length);
  }

  useEffect(() => {
    const on = () => setOnline(true); const off = () => setOnline(false);
    addEventListener('online', on); addEventListener('offline', off);
    api.me().then(res => bootstrap(res.user, res.wallet)).catch(() => null).finally(() => setLoading(false));
    return () => { removeEventListener('online', on); removeEventListener('offline', off); };
  }, []);

  const refToken = useMemo(() => new URLSearchParams(location.search).get('ref'), []);

  if (loading) return <div className="loading"><Radio className="spin" /> Cargando wallet local...</div>;
  if (!user) return <Login onLogin={(u, w) => { bootstrap(u, w); }} />;

  return <div className="app-shell local-first-shell">
    <header className="topbar glass">
      <div className="brand"><span>ðŸŽ</span><div><strong>Juega123 Local-First</strong><small>DB en telÃ©fono + sync blockchain-ready</small></div></div>
      <nav>
        <button className={tab === 'games' ? 'active' : ''} onClick={() => setTab('games')}><Dice5 size={17}/> Derby</button>
        <button className={tab === 'pool' ? 'active' : ''} onClick={() => setTab('pool')}><Trophy size={17}/> Pool</button>
        <button className={tab === 'history' ? 'active' : ''} onClick={() => setTab('history')}><History size={17}/> Historial</button>
        <button className={tab === 'audit' ? 'active' : ''} onClick={() => setTab('audit')}><Blocks size={17}/> AuditorÃ­a</button>
      </nav>
      <button className="ghost" onClick={() => { logout(); location.reload(); }}><LogOut size={18}/> Salir</button>
    </header>

    {refToken && <div className="ref-banner glass">Entraste con token de referido: <strong>{refToken}</strong>.</div>}
    <div className="local-first-banner glass">{online ? <Wifi size={18}/> : <WifiOff size={18}/>} Base de datos principal: <strong>IndexedDB en este telÃ©fono</strong>. Hacia afuera solo se envÃ­an movimientos firmados.</div>

    <main>
      <WalletCards wallet={localWallet} syncCount={syncCount} online={online} />
      {tab === 'games' && <DerbyLocalFirstPanel user={user} wallet={localWallet} refreshLocal={() => refreshLocal(user.id)} />}
      {tab === 'pool' && <PoolPanel />}
      {tab === 'history' && <HistoryPanel userId={user.id} />}
      {tab === 'audit' && <AuditPanel />}
      <div className="danger-zone glass"><small>Inicial del servidor: Real {money(serverWallet?.realBalance || 0)} Â· Demo {money(serverWallet?.demoBalance || 0)}</small><button className="danger" onClick={async () => { if (confirm('Â¿Borrar DB local de este navegador?')) { await clearLocalFirstDb(); location.reload(); } }}>Reset DB local</button></div>
    </main>
  </div>;
}

