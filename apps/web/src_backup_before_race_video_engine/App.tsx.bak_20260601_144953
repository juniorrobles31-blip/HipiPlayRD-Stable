function HistoryPanel({ userId }: { userId: string }) {
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [movements, setMovements] = useState<LocalLedgerMovement[]>([]);
  async function load() {
    setBets(await localDerbyHistory(userId));
    const all = await dbGetAll<LocalLedgerMovement>('ledger_movements');
    setMovements(all.filter(m => m.userId === userId).sort((a, b) => b.createdAt.localeCompare(a.createdAt)));
  }
  useEffect(() => { load(); const t = setInterval(load, 3000); return () => clearInterval(t); }, [userId]);
  return <section className="glass history-card"><h2><History /> Historial local del telÃ©fono</h2>
    <h3>Boletos Derby</h3>{bets.length === 0 ? <p>No hay boletos locales.</p> : bets.map(b => <div className="history-row" key={b.id}><strong>{b.raceCode}</strong><span>{b.mode}</span><span>Caballo #{b.selectedHorse}</span><span>{money(b.amount)}</span><span className={b.profitLoss >= 0 ? 'pos' : 'neg'}>{b.status} Â· {money(b.profitLoss)}</span><small>{new Date(b.createdAt).toLocaleString()}</small></div>)}
    <h3>Ledger local</h3>{movements.map(m => <div className="history-row" key={m.movementId}><strong>{m.type}</strong><span>{m.mode}</span><span>-{money(m.amountSpent)} / +{money(m.amountAdded)}</span><span>{m.syncStatus}</span><small>{m.movementId}</small></div>)}
  </section>;
}

function AuditPanel() {
  const [queue, setQueue] = useState<SyncQueueItem[]>([]);
  const [audits, setAudits] = useState<any[]>([]);
  async function load() {
    setQueue(await dbGetAll<SyncQueueItem>('sync_queue'));
    api.audits().then(r => setAudits(r.audits || [])).catch(() => setAudits([]));
  }
  useEffect(() => { load(); const t = setInterval(load, 3000); return () => clearInterval(t); }, []);
  return <section className="glass history-card"><h2><Blocks /> AuditorÃ­a local + blockchain-ready</h2>
    <h3>Cola local IndexedDB</h3>{queue.length === 0 ? <p>No hay movimientos en cola.</p> : queue.map(q => <div className="audit-row" key={q.id}><strong>{q.payload.type}</strong><code>{q.payload.payloadHash}</code><span>{q.status}</span></div>)}
    <h3>AuditorÃ­a recibida por backend</h3>{audits.length === 0 ? <p>No hay hashes pendientes en backend.</p> : audits.map(a => <div className="audit-row" key={a.id}><strong>{a.eventType}</strong><code>{a.chainHash}</code><span>{a.blockchainStatus}</span></div>)}
