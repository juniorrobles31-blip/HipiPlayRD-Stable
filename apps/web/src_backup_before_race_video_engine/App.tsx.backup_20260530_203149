function RaceTrack({ seed, selectedHorse, hasTicket, now, marketOrder }: { seed: LocalRaceSeed | null; selectedHorse?: number; hasTicket?: boolean; now: number; marketOrder?: number[] }) {
  const phase = seed ? racePhase(seed, now) : 'betting';
  const resultOrder = seed && phase === 'revealed' && marketOrder && marketOrder.length ? marketOrder : [];
  const top3 = resultOrder.slice(0, 3);
  const progress = seed ? progressOf(seed, now) : 0;
  const closeIn = seed ? seconds(new Date(seed.betClosesAt).getTime() - now) : 0;
  const revealIn = seed ? seconds(new Date(seed.revealsAt).getTime() - now) : 0;
  const phaseLabel = phase === 'betting'
    ? hasTicket ? 'Boleto generado · caballos calentando' : 'Apuestas abiertas · selecciona tu caballo'
    : phase === 'locked'
      ? 'Puertas cerradas · carrera en vivo'
      : 'Foto finish · resultado oficial local calculado';

  return <div className={`derby-stadium phase-${phase} local-first-race`}>
    <div className="stadium-lights">
      <span className={phase === 'locked' ? 'light amber on' : 'light amber'}></span>
      <span className={phase === 'betting' ? 'light green on' : 'light green'}></span>
      <span className={phase === 'revealed' ? 'light gold on' : 'light gold'}></span>
    </div>

    <div className="race-progress-panel">
      <div>
        <strong>{phaseLabel}</strong>
        <small>{phase === 'revealed' ? 'Puedes apostar otra vez en la próxima carrera.' : phase === 'locked' ? `Resultado en ${revealIn}s` : `Cierre de apuestas en ${closeIn}s`}</small>
      </div>
      <div className="race-progress-ring" style={{ ['--p' as string]: `${progress * 100}%` }}>
        <span>{phase === 'revealed' ? 'FIN' : phase === 'locked' ? revealIn : closeIn}</span>
      </div>
    </div>

    <div className="race-scene">
      <div className="grandstand"><span>🏟️</span><span>📣</span><span>🎺</span><span>🏁</span><span>🎟️</span><span>✨</span></div>
      <div className="finish-line"><span>META</span></div>
      <div className="starting-gate"><span>GATE</span></div>
      <div className="race-track derby-track cinematic">
        {[1,2,3,4,5,6].map(h => {
          const position = resultOrder.indexOf(h) + 1;
          const isTop = top3.includes(h);
          const pulse = Math.sin((now / 320) + h) * 2.5;
          const bettingX = 8 + h * 1.8 + pulse;
          const lockedX = 18 + ((now / 1000 + h) % 1) * 35 + h * 2;
          const finalX = phase === 'revealed' ? 92 - (Math.max(position, 1) - 1) * 8.5 : 12;
          const x = phase === 'revealed' ? finalX : phase === 'locked' ? Math.min(82, lockedX) : bettingX;
          return <div key={h} className={`lane ${selectedHorse === h ? 'selected' : ''} ${isTop ? 'winner-lane' : ''}`}>
            <span className="lane-number">#{h}</span>
            <div className="lane-dirt"></div>
            <div className="horse-runner" style={{ ['--x' as string]: `${x}%`, ['--delay' as string]: `${h * 80}ms` }}>
              <span className="horse-shadow"></span>
              <span className="horse-sprite">🐎</span>
              <span className="jockey">{h}</span>
            </div>
            {phase === 'revealed' && <em className={isTop ? 'top3' : ''}>{position}º</em>}
          </div>;
        })}
      </div>
    </div>
  </div>;
}

function DerbyLocalFirstPanel({ user, wallet, refreshLocal }: { user: User; wallet: LocalWalletState | null; refreshLocal: () => Promise<void> }) {
  const [seed, setSeed] = useState<LocalRaceSeed | null>(null);
  const [now, setNow] = useState(Date.now());
  const [mode, setMode] = useState<WalletMode>('demo');
  const [amount, setAmount] = useState(100);
  const [horse, setHorse] = useState(1);
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [message, setMessage] = useState('');
  const [loading, setLoading] = useState(false);
  const [syncing, setSyncing] = useState(false);
  const [exposure, setExposure] = useState<DerbyMarketExposure>(() => createEmptyExposure('initial'));
  const [marketMessage, setMarketMessage] = useState('');

  async function loadSeed() {
    try {
      const res = await api.currentSeed();
      setSeed(res.seed);
      setExposure(prev => prev.raceId === res.seed.raceId ? prev : createEmptyExposure(res.seed.raceId));
    } catch {
      const local = await deriveLocalRaceSeed();
      setSeed(local);
      setExposure(prev => prev.raceId === local.raceId ? prev : createEmptyExposure(local.raceId));
    }
  }

  async function loadLocalBets() {
    const all = await localDerbyHistory(user.id);
    setBets(all);
  }

  async function resolveIfNeeded(currentSeed: LocalRaceSeed) {
    const phase = racePhase(currentSeed, Date.now());
    if (phase !== 'revealed') return;

    const status = getMarketStatus(exposure);
    if (!status.canResolve) {
      setMarketMessage(`Esperando más apuestas para cerrar la calculadora: ${status.reason}`);
      return;
    }

    const resultOrder = buildResultOrderFromExposure(exposure, currentSeed.seed);
    const resolved = await resolvePendingLocalBets(user.id, currentSeed.raceId, currentSeed.code, resultOrder);
    if (resolved.length) {
      setMessage(`Resultado aplicado por calculadora de menor exposición. ${resolved[0].status === 'won' ? 'Ganaste Top 3.' : 'Fuera del Top 3.'}`);
      await refreshLocal();
      await syncNow();
    }
  }

  async function tick() {
    const t = Date.now();
    setNow(t);
    const localSeed = await deriveLocalRaceSeed(t);
    setSeed(prev => prev?.raceId === localSeed.raceId ? prev : localSeed);

    setExposure(prev => {
      const base = prev.raceId === localSeed.raceId ? prev : createEmptyExposure(localSeed.raceId);
      const phaseNow = racePhase(localSeed, t);
      return phaseNow === 'betting' ? simulatePublicBettingStep(base, t) : base;
    });

    await resolveIfNeeded(localSeed);
    await loadLocalBets();
  }

  useEffect(() => {
    loadSeed().then(loadLocalBets);
    const interval = setInterval(tick, 1000);
    return () => clearInterval(interval);
  }, [user.id]);

  async function syncNow() {
    setSyncing(true);
    try {
      await syncPendingQueue(20);
    } finally {
      setSyncing(false);
      await refreshLocal();
    }
  }

  async function bet() {
    if (!seed) return;
    setLoading(true);
    setMessage('');
    try {
      const phase = racePhase(seed, Date.now());
      const status = getMarketStatus(exposure);

      if (phase !== 'betting') throw new Error('Apuestas cerradas para esta carrera. Espera la próxima.');
      if (!status.canAcceptBet) throw new Error(`La calculadora cerró apuestas: ${status.reason}`);

      const res = await placeLocalDerbyBet({ userId: user.id, raceId: seed.raceId, raceCode: seed.code, mode, horse, amount });

      setExposure(prev => addBetToExposure(prev, horse, amount, user.id, 'local'));
      setMarketMessage('Tu apuesta entró en la calculadora. El Top 3 se definirá por los caballos menos apostados.');
      setMessage(`Boleto generado localmente: ${res.bet.id}. Movimiento firmado: ${res.movement.movementId}.`);
      await refreshLocal();
      await loadLocalBets();
      await syncNow();
    } catch (err) {
      setMessage(err instanceof Error ? err.message : 'Error generando boleto local');
    } finally {
      setLoading(false);
    }
  }

  const phase = seed ? racePhase(seed, now) : 'betting';
  const marketStatus = getMarketStatus(exposure);
  const marketOrder = seed && marketStatus.canResolve
    ? buildResultOrderFromExposure(exposure, seed.seed)
    : [];

  const resultOrder = seed && phase === 'revealed' && marketOrder.length
    ? marketOrder
    : [];

  const top3 = resultOrder.slice(0, 3);
  const activeBet = seed ? bets.find(b => b.raceId === seed.raceId) : undefined;
  const lastBet = bets[0];
  const bettingOpen = phase === 'betting' && !activeBet && marketStatus.canAcceptBet;

  return <div className="play-card glass derby-card local-first-card">
    <div className="play-hero derby-hero">
      <div className="big-icon">🐎</div>
      <div>
        <h2>Derby Minute Local-First</h2>
        <p>La carrera se calcula en el teléfono con semilla global. La wallet local firma y sincroniza solo resúmenes contables.</p>
      </div>
      <div className="derby-status"><span className={bettingOpen ? 'live-dot' : 'lock-dot'}></span>{phase === 'betting' ? 'Apuestas abiertas' : phase === 'locked' ? 'Carrera en vivo' : 'Resultado revelado'}</div>
    </div>

    <div className="derby-grid">
      <div className="derby-info"><Clock3 size={17}/><span>Carrera</span><strong>{seed?.code || '...'}</strong></div>
      <div className="derby-info"><ShieldCheck size={17}/><span>Seed commit</span><code>{seed?.seedCommit.slice(0, 18)}...</code></div>
      <div className="derby-info"><Trophy size={17}/><span>Top 3</span><strong>{top3.length ? top3.join(' · ') : 'Pendiente'}</strong></div>
      <div className="derby-info"><Database size={17}/><span>DB principal</span><strong>Teléfono</strong></div>
    </div>

    <div className="market-calculator-panel">
      <div className="market-header">
        <div>
          <strong>Calculadora de exposición</strong>
          <small>El sistema espera apuestas, aplica tope y selecciona como Top 3 los caballos menos apostados.</small>
        </div>
        <span className={marketStatus.canAcceptBet ? 'market-badge open' : 'market-badge closed'}>
          {marketStatus.label}
        </span>
      </div>

      <div className="market-limits">
        <span>Apuestas: <strong>{exposure.totalBets}</strong> / {MARKET_CONFIG.maxBetsPerRace}</span>
        <span>Volumen: <strong>{money(exposure.totalVolume)}</strong> / {money(MARKET_CONFIG.maxVolumePerRace)}</span>
        <span>Mínimo para cerrar: {MARKET_CONFIG.minBetsToResolve} apuestas o {money(MARKET_CONFIG.minVolumeToResolve)}</span>
      </div>

      <div className="horse-exposure-grid">
        {[1,2,3,4,5,6].map(n => {
          const isLeast = calculateLeastBetTop3(exposure).includes(n);
          return <div key={n} className={isLeast ? 'horse-exposure least' : 'horse-exposure'}>
            <span>#{n}</span>
            <strong>{money(exposure.totals[n] || 0)}</strong>
            <small>{exposure.counts[n] || 0} apuestas</small>
          </div>;
        })}
      </div>

      {(marketMessage || !marketStatus.canResolve) && <div className="market-note">
        {marketMessage || `La calculadora todavía espera más participación: ${marketStatus.reason}`}
      </div>}
    </div>

    <div className="mode-toggle">
      <button className={mode === 'demo' ? 'active' : ''} onClick={() => setMode('demo')}>Demo</button>
      <button className={mode === 'real' ? 'active' : ''} onClick={() => setMode('real')}>Real</button>
    </div>

    <div className="form-grid two">
      <label>Monto<input type="number" min={1} value={amount} onChange={e => setAmount(Number(e.target.value))} disabled={!bettingOpen} /></label>
      <label>Caballo<select value={horse} onChange={e => setHorse(Number(e.target.value))} disabled={!bettingOpen}>{[1,2,3,4,5,6].map(n => <option key={n} value={n}>Caballo #{n}</option>)}</select></label>
    </div>

    <div className="derby-countdown-board">
      <div className="board-item active"><span>01</span><strong>Boleto</strong><small>{activeBet ? 'Generado' : bettingOpen ? 'Disponible' : 'Cerrado'}</small></div>
      <div className="board-line"></div>
      <div className={phase === 'locked' || phase === 'revealed' ? 'board-item active' : 'board-item'}><span>02</span><strong>Carrera</strong><small>{phase === 'locked' ? 'Corriendo' : phase === 'revealed' ? 'Terminada' : 'Pendiente'}</small></div>
      <div className="board-line"></div>
      <div className={phase === 'revealed' ? 'board-item active' : 'board-item'}><span>03</span><strong>Contabilidad</strong><small>{phase === 'revealed' ? 'Aplicada' : 'Pendiente'}</small></div>
    </div>

    <RaceTrack seed={seed} selectedHorse={activeBet?.selectedHorse || horse} hasTicket={Boolean(activeBet)} now={now} marketOrder={marketOrder} />

    <button className="primary wide" onClick={bet} disabled={!bettingOpen || loading}>{loading ? 'Firmando...' : activeBet ? 'Boleto generado' : `Apostar local al #${horse}`}</button>
    <div className="action-row">
      <button className="secondary" onClick={loadSeed}><RefreshCcw size={16}/> Refrescar semilla</button>
      <button className="secondary" onClick={syncNow} disabled={syncing}>{syncing ? 'Sincronizando...' : 'Sincronizar contabilidad'}</button>
    </div>

    {message && <div className="result-card neutral"><strong>{message}</strong></div>}
    {activeBet && <div className={activeBet.status === 'pending' ? 'result-card neutral' : activeBet.status === 'won' ? 'result-card win' : 'result-card lose'}>
      <strong>{activeBet.status === 'pending' ? 'Boleto activo' : activeBet.status === 'won' ? 'Ganaste Top 3' : 'Fuera del Top 3'}</strong>
      <span>Caballo #{activeBet.selectedHorse} · {money(activeBet.amount)} · Pago {money(activeBet.payout)}</span>
    </div>}

    {resultOrder.length > 0 && <div className="derby-result"><strong>Resultado calculado en el teléfono:</strong> {resultOrder.map((h, i) => <span key={h} className={i < 3 ? 'podium' : ''}>{i + 1}º: #{h}</span>)}</div>}
    {lastBet && <small className="muted">Último boleto: {lastBet.raceCode} · {lastBet.status} · {money(lastBet.profitLoss)}</small>}
    <small className="muted">Balance local disponible: {mode === 'demo' ? money(wallet?.demoBalance || 0) : money(wallet?.realBalance || 0)}</small>
  </div>;
}

function PoolPanel() {
  const [pool, setPool] = useState<any>(null);
  const [ref, setRef] = useState('');
  const [token, setTokenState] = useState('');
  const [purchaseAmount, setPurchaseAmount] = useState(500);

  async function load() { setPool(await api.pool()); }
  useEffect(() => { load().catch(() => null); const t = setInterval(() => load().catch(() => null), 15000); return () => clearInterval(t); }, []);

  async function create() { const res = await api.createReferral(); setRef(res.referral.url); }
  async function confirmPurchase() { await api.confirmPurchase(token, purchaseAmount); await load(); }

  return <section className="pool-grid">
    <div className="glass pool-card"><h2><Trophy /> Pool de Invitación</h2><p>Este módulo sigue sincronizado con backend. La wallet del juego principal sigue siendo local-first.</p><div className="pool-money">{money(pool?.round?.poolAmount || 0)}</div><small>Ronda: {pool?.round?.code || '...'}</small></div>
    <div className="glass pool-card"><h3><Copy /> Mi link</h3><button className="primary" onClick={create}>Generar link</button>{ref && <><input value={ref} readOnly /><button className="secondary" onClick={() => navigator.clipboard.writeText(ref)}>Copiar</button></>}</div>
    <div className="glass pool-card"><h3>Simular compra referida</h3><input placeholder="Token" value={token} onChange={e => setTokenState(e.target.value)} /><input type="number" value={purchaseAmount} onChange={e => setPurchaseAmount(Number(e.target.value))} /><button className="primary" onClick={confirmPurchase}>Confirmar</button></div>
    <div className="glass pool-card leaderboard"><h3>Ranking</h3>{(pool?.leaderboard || []).map((row: any, i: number) => <div className="leader-row" key={row.userId}><span>#{i + 1}</span><strong>{row.userId}</strong><em>{row.scoreCount} compras</em></div>)}</div>
  </section>;
}

function HistoryPanel({ userId }: { userId: string }) {
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [movements, setMovements] = useState<LocalLedgerMovement[]>([]);
  async function load() {
    setBets(await localDerbyHistory(userId));
    const all = await dbGetAll<LocalLedgerMovement>('ledger_movements');
    setMovements(all.filter(m => m.userId === userId).sort((a, b) => b.createdAt.localeCompare(a.createdAt)));
  }
  useEffect(() => { load(); const t = setInterval(load, 3000); return () => clearInterval(t); }, [userId]);
  return <section className="glass history-card"><h2><History /> Historial local del teléfono</h2>
    <h3>Boletos Derby</h3>{bets.length === 0 ? <p>No hay boletos locales.</p> : bets.map(b => <div className="history-row" key={b.id}><strong>{b.raceCode}</strong><span>{b.mode}</span><span>Caballo #{b.selectedHorse}</span><span>{money(b.amount)}</span><span className={b.profitLoss >= 0 ? 'pos' : 'neg'}>{b.status} · {money(b.profitLoss)}</span><small>{new Date(b.createdAt).toLocaleString()}</small></div>)}
    <h3>Ledger local</h3>{movements.map(m => <div className="history-row" key={m.movementId}><strong>{m.type}</strong><span>{m.mode}</span><span>-{money(m.amountSpent)} / +{money(m.amountAdded)}</span><span>{m.syncStatus}</span><small>{m.movementId}</small></div>)}
  </section>;
}

function AuditPanel() {
  const [queue, setQueue] = useState<SyncQueueItem[]>([]);
  const [audits, setAudits] = useState<any[]>([]);
  async function load() {
    setQueue(await dbGetAll<SyncQueueItem>('sync_queue'));
    api.audits().then(r => setAudits(r.audits || [])).catch(() => setAudits([]));
  }
  useEffect(() => { load(); const t = setInterval(load, 3000); return () => clearInterval(t); }, []);
  return <section className="glass history-card"><h2><Blocks /> Auditoría local + blockchain-ready</h2>
    <h3>Cola local IndexedDB</h3>{queue.length === 0 ? <p>No hay movimientos en cola.</p> : queue.map(q => <div className="audit-row" key={q.id}><strong>{q.payload.type}</strong><code>{q.payload.payloadHash}</code><span>{q.status}</span></div>)}
    <h3>Auditoría recibida por backend</h3>{audits.length === 0 ? <p>No hay hashes pendientes en backend.</p> : audits.map(a => <div className="audit-row" key={a.id}><strong>{a.eventType}</strong><code>{a.chainHash}</code><span>{a.blockchainStatus}</span></div>)}
  </section>;
}

export function App() {
  const [user, setUser] = useState<User | null>(null);
  const [serverWallet, setServerWallet] = useState<Wallet | null>(null);
  const [localWallet, setLocalWallet] = useState<LocalWalletState | null>(null);
  const [syncCount, setSyncCount] = useState(0);
  const [online, setOnline] = useState(navigator.onLine);
  const [tab, setTab] = useState<Tab>('games');
  const [loading, setLoading] = useState(true);

  async function refreshLocal(userId = user?.id) {
    if (!userId) return;
    const wallet = await getLocalWallet(userId);
    setLocalWallet(wallet);
    setSyncCount((await pendingSyncItems()).length);
  }

  async function bootstrap(u: User, w: Wallet) {
    setUser(u); setServerWallet(w);
    const local = await initLocalWallet(u.id, { demoBalance: w.demoBalance, realBalance: w.realBalance, giftLocked: w.giftLocked });
    setLocalWallet(local);
    setSyncCount((await pendingSyncItems()).length);
  }

  useEffect(() => {
    const on = () => setOnline(true); const off = () => setOnline(false);
    addEventListener('online', on); addEventListener('offline', off);
    api.me().then(res => bootstrap(res.user, res.wallet)).catch(() => null).finally(() => setLoading(false));
    return () => { removeEventListener('online', on); removeEventListener('offline', off); };
  }, []);

  const refToken = useMemo(() => new URLSearchParams(location.search).get('ref'), []);

  if (loading) return <div className="loading"><Radio className="spin" /> Cargando wallet local...</div>;
  if (!user) return <Login onLogin={(u, w) => { bootstrap(u, w); }} />;

  return <div className="app-shell local-first-shell">
    <header className="topbar glass">
      <div className="brand"><span>🐎</span><div><strong>Juega123 Local-First</strong><small>DB en teléfono + sync blockchain-ready</small></div></div>
      <nav>
        <button className={tab === 'games' ? 'active' : ''} onClick={() => setTab('games')}><Dice5 size={17}/> Derby</button>
        <button className={tab === 'pool' ? 'active' : ''} onClick={() => setTab('pool')}><Trophy size={17}/> Pool</button>
        <button className={tab === 'history' ? 'active' : ''} onClick={() => setTab('history')}><History size={17}/> Historial</button>
        <button className={tab === 'audit' ? 'active' : ''} onClick={() => setTab('audit')}><Blocks size={17}/> Auditoría</button>
      </nav>
      <button className="ghost" onClick={() => { logout(); location.reload(); }}><LogOut size={18}/> Salir</button>
    </header>

    {refToken && <div className="ref-banner glass">Entraste con token de referido: <strong>{refToken}</strong>.</div>}
    <div className="local-first-banner glass">{online ? <Wifi size={18}/> : <WifiOff size={18}/>} Base de datos principal: <strong>IndexedDB en este teléfono</strong>. Hacia afuera solo se envían movimientos firmados.</div>

    <main>
      <WalletCards wallet={localWallet} syncCount={syncCount} online={online} />
      {tab === 'games' && <DerbyLocalFirstPanel user={user} wallet={localWallet} refreshLocal={() => refreshLocal(user.id)} />}
      {tab === 'pool' && <PoolPanel />}
      {tab === 'history' && <HistoryPanel userId={user.id} />}
      {tab === 'audit' && <AuditPanel />}
      <div className="danger-zone glass"><small>Inicial del servidor: Real {money(serverWallet?.realBalance || 0)} · Demo {money(serverWallet?.demoBalance || 0)}</small><button className="danger" onClick={async () => { if (confirm('¿Borrar DB local de este navegador?')) { await clearLocalFirstDb(); location.reload(); } }}>Reset DB local</button></div>
    </main>
  </div>;
}
