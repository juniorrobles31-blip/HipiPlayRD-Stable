function RaceTrack({ visualRace, now, selectedHorse }: { visualRace: VisualRace | null; now: number; selectedHorse: number }) {
  const running = Boolean(visualRace && visualRace.status === 'running');
  const finished = Boolean(visualRace && visualRace.status === 'finished');
  const elapsed = visualRace ? Math.max(0, now - visualRace.startedAt) : 0;
  const progress = visualRace ? Math.min(1, elapsed / RACE_VISUAL_DURATION_MS) : 0;
  const secondsLeft = visualRace ? Math.max(0, Math.ceil((RACE_VISUAL_DURATION_MS - elapsed) / 1000)) : 60;
  const order = visualRace?.resultOrder?.length ? visualRace.resultOrder : HORSES;
  const top3 = order.slice(0, 3);
  const won = visualRace ? top3.includes(visualRace.selectedHorse) : false;
  const leadHorse = order[0];
  const ease = progress < 1 ? 1 - Math.pow(1 - progress, 2.2) : 1;

  return <section className={`race-tv glass ${running ? 'race-running' : ''} ${finished ? 'race-finished' : ''}`}>
    <div className="race-tv-header">
      <div>
        <span className="live-badge">EN VIVO</span>
        <strong>{running ? 'Carrera en vivo - 60 segundos' : finished ? 'Resultado oficial' : 'Listo para iniciar carrera'}</strong>
        <small>{running ? `Tiempo restante: ${secondsLeft}s` : finished ? `Ganador: Caballo #${leadHorse}` : 'La carrera inicia al generar el boleto.'}</small>
      </div>
      <div className="race-clock">
        <span>{running ? secondsLeft : finished ? 'FIN' : '60'}</span>
      </div>
    </div>

    <div className="race-scene realistic-scene">
      <div className="grandstand clean-grandstand">
        <span>GRADAS</span>
        <span>PUBLICO</span>
        <span>TRANSMISION</span>
        <span>META</span>
      </div>
      <div className="starting-gate realistic-gate"><span>PARTIDA</span></div>
      <div className="finish-line realistic-finish"><span>META</span></div>

      <div className="race-track derby-track cinematic realistic-track">
        {HORSES.map(horse => {
          const rankIndex = order.indexOf(horse);
          const rank = rankIndex >= 0 ? rankIndex + 1 : horse;
          const startX = 6;
          const finalX = 93 - ((rank - 1) * 4.6);
          const laneStagger = (horse - 3) * 0.2;
          const gallopSurge = running ? Math.sin(now / (180 + horse * 9) + horse) * (1.35 + (rank <= 3 ? 0.35 : 0)) : 0;
          const midRaceDrama = running && progress > 0.25 && progress < 0.88 ? Math.sin(now / 780 + rank) * 2.1 : 0;
          const x = finished
            ? finalX
            : running
              ? Math.min(94, Math.max(5, startX + (finalX - startX) * ease + gallopSurge + midRaceDrama + laneStagger))
              : startX + horse * 0.7;

          return <RaceHorse
            key={horse}
            horse={horse}
            x={x}
            running={running}
            selected={visualRace ? visualRace.selectedHorse === horse : selectedHorse === horse}
            winnerLane={finished && top3.includes(horse)}
            rank={finished ? rank : undefined}
          />;
        })}
      </div>
    </div>

    {finished && visualRace && <div className={`race-final-board ${won ? 'win' : 'lose'}`}>
      <div>
        <span className="result-pill">{won ? 'GANASTE' : 'PERDISTE'}</span>
        <strong>Tu caballo: #{visualRace.selectedHorse}</strong>
        <small>{won ? `Premio estimado: ${coins(visualRace.amount * 2)} monedas` : `Perdiste ${coins(visualRace.amount)} monedas`}</small>
      </div>
      <div className="top3-board">
        <span>Top 3 ganador</span>
        <strong>{top3.map(h => `#${h}`).join('  -  ')}</strong>
      </div>
    </div>}
  </section>;
}

function MarketPanel({ exposure, resultOrder }: { exposure: DerbyMarketExposure | null; resultOrder?: number[] }) {
  const least = exposure ? calculateLeastBetTop3(exposure) : [];
  return <section className="market-player-panel glass">
    <div className="market-player-head">
      <div>
        <strong>Mercado de la carrera</strong>
        <small>El Top 3 se calcula con los caballos menos apostados.</small>
      </div>
      <span>{exposure ? `${exposure.totalBets} apuestas` : 'Pendiente'}</span>
    </div>
    <div className="horse-exposure-grid clean-exposure-grid">
      {HORSES.map(h => {
        const isTop = resultOrder?.slice(0, 3).includes(h) || least.includes(h);
        return <div key={h} className={`horse-exposure ${isTop ? 'least' : ''}`}>
          <span>#{h}</span>
          <strong>{coins(exposure?.totals[h] || 0)}</strong>
          <small>{coins(exposure?.counts[h] || 0)} apuestas</small>
        </div>;
      })}
    </div>
  </section>;
}

function DerbyGame({ user, wallet, refreshLocal }: { user: User; wallet: LocalWalletState | null; refreshLocal: () => Promise<void> }) {
  const [seed, setSeed] = useState<LocalRaceSeed | null>(null);
  const [now, setNow] = useState(Date.now());
  const [amount, setAmount] = useState(100);
  const [horse, setHorse] = useState(1);
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [message, setMessage] = useState('');
  const [loading, setLoading] = useState(false);
  const [syncing, setSyncing] = useState(false);
  const [visualRace, setVisualRace] = useState<VisualRace | null>(null);
  const [lastExposure, setLastExposure] = useState<DerbyMarketExposure | null>(null);

  async function loadLocalBets() {
    const all = await localDerbyHistory(user.id);
    setBets(all);
  }

  async function loadSeed() {
    const nextSeed = await deriveLocalRaceSeed(Date.now());
    setSeed(nextSeed);
  }

  async function syncNowQuietly() {
    setSyncing(true);
    try {
      await syncPendingQueue(20);
    } catch {
      // La sincronización no debe interrumpir la experiencia de juego.
    } finally {
      setSyncing(false);
      await refreshLocal();
    }
  }

  useEffect(() => {
    loadSeed().catch(() => null);
    loadLocalBets().catch(() => null);
    const interval = setInterval(() => setNow(Date.now()), 250);
    const seedInterval = setInterval(() => loadSeed().catch(() => null), 10000);
    const historyInterval = setInterval(() => loadLocalBets().catch(() => null), 3000);
    return () => {
      clearInterval(interval);
      clearInterval(seedInterval);
      clearInterval(historyInterval);
    };
  }, [user.id]);

  async function finishRace(race: VisualRace) {
    setVisualRace(prev => prev && prev.id === race.id ? { ...prev, status: 'finished', resolved: true } : prev);
    const resolved = await resolvePendingLocalBets(user.id, race.raceId, race.raceCode, race.resultOrder);
    const top3 = race.resultOrder.slice(0, 3);
    const won = top3.includes(race.selectedHorse);
    setMessage(won
      ? `GANASTE. Tu caballo #${race.selectedHorse} quedó dentro del Top 3: ${top3.map(h => `#${h}`).join(', ')}.`
      : `PERDISTE. Top 3 ganador: ${top3.map(h => `#${h}`).join(', ')}.`
    );
    if (resolved.length === 0) await loadLocalBets();
    await refreshLocal();
    await loadLocalBets();
    await syncNowQuietly();
  }

  useEffect(() => {
    if (!visualRace || visualRace.status !== 'running' || visualRace.resolved) return;
    if (now - visualRace.startedAt < RACE_VISUAL_DURATION_MS) return;
    finishRace(visualRace).catch(err => setMessage(normalizeError(err)));
  }, [now, visualRace]);

  async function bet() {
    if (visualRace?.status === 'running') {
      setMessage('Hay una carrera corriendo. Espera el resultado para apostar de nuevo.');
      return;
    }

    const safeAmount = Math.floor(Number(amount || 0));
    if (!Number.isFinite(safeAmount) || safeAmount <= 0) {
      setMessage('Ingresa una cantidad válida de monedas.');
      return;
    }

    if ((wallet?.demoBalance || 0) < safeAmount) {
      setMessage('Monedas insuficientes para realizar esta apuesta.');
      return;
    }

    setLoading(true);
    setMessage('');
    try {
      const baseSeed = await deriveLocalRaceSeed(Date.now());
      const uniqueRaceId = `${baseSeed.raceId}-${Date.now().toString(36)}`;
      const raceSeed = { ...baseSeed, raceId: uniqueRaceId };
      setSeed(raceSeed);

      const res = await placeLocalDerbyBet({
        userId: user.id,
        raceId: raceSeed.raceId,
        raceCode: raceSeed.code,
        mode: 'demo',
        horse,
        amount: safeAmount,
      });

      const publicExposure = buildDemoMarket(raceSeed.raceId, raceSeed.seed);
      const finalExposure = addBetToExposure(publicExposure, horse, safeAmount, user.id, 'local');
      const resultOrder = buildResultOrderFromExposure(finalExposure, raceSeed.seed);
      setLastExposure(finalExposure);
      setVisualRace({
        id: `VR-${Date.now()}`,
        raceId: raceSeed.raceId,
        raceCode: raceSeed.code,
        selectedHorse: horse,
        amount: safeAmount,
        betId: res.bet.id,
        startedAt: Date.now(),
        resultOrder,
        exposure: finalExposure,
        status: 'running',
        resolved: false,
      });

      setMessage(`Boleto generado: ${res.bet.id}. La carrera inició y durará 60 segundos.`);
      await refreshLocal();
      await loadLocalBets();
      syncNowQuietly();
    } catch (err) {
      setMessage(normalizeError(err));
    } finally {
      setLoading(false);
    }
  }

  const pendingCount = bets.filter(b => b.status === 'pending').length;
  const lastBet = bets[0];
  const raceBusy = visualRace?.status === 'running';
  const top3 = visualRace?.resultOrder.slice(0, 3) || [];

  return <div className="player-screen">
    <PlayerSummary wallet={wallet} pendingCount={pendingCount} lastBet={lastBet} />

    <section className="game-hero glass">
      <div className="game-title-block">
        <div className="big-icon text-icon">DERBY</div>
        <div>
          <h2>Derby Minute</h2>
          <p>Apuesta con monedas. Al generar el boleto, la carrera inicia inmediatamente y dura 60 segundos.</p>
        </div>
      </div>
      <div className="derby-status player-status"><span className={raceBusy ? 'live-dot racing' : 'live-dot'}></span>{raceBusy ? 'Carrera en vivo' : 'Apuestas abiertas'}</div>
    </section>

    <div className="bet-panel glass">
      <div className="bet-field">
        <label>Cantidad de monedas</label>
        <input type="number" min={1} value={amount} onChange={e => setAmount(Number(e.target.value))} disabled={raceBusy || loading} />
      </div>
      <div className="bet-field">
        <label>Caballo</label>
        <select value={horse} onChange={e => setHorse(Number(e.target.value))} disabled={raceBusy || loading}>
          {HORSES.map(n => <option key={n} value={n}>Caballo #{n}</option>)}
        </select>
      </div>
      <button className="primary bet-button" onClick={bet} disabled={raceBusy || loading}>
        {loading ? 'Generando boleto...' : raceBusy ? 'Carrera en vivo' : `Apostar ${coins(amount)} monedas al #${horse}`}
      </button>
    </div>

    <RaceTrack visualRace={visualRace} now={now} selectedHorse={horse} />
    <MarketPanel exposure={visualRace?.exposure || lastExposure} resultOrder={visualRace?.status === 'finished' ? visualRace.resultOrder : undefined} />

    {message && <div className={`result-card ${message.startsWith('GANASTE') ? 'win' : message.startsWith('PERDISTE') ? 'lose' : 'neutral'}`}>
      <strong>{message}</strong>
    </div>}

    {top3.length > 0 && visualRace?.status === 'finished' && <div className="derby-result clean-result">
      <strong>Top 3 ganador:</strong>
      {top3.map((h, i) => <span key={h} className="podium">{i + 1}o: #{h}</span>)}
    </div>}

    <div className="action-row clean-actions">
      <button className="secondary" onClick={loadSeed}><RefreshCcw size={16}/> Nueva referencia</button>
      <button className="secondary" onClick={syncNowQuietly} disabled={syncing}>{syncing ? 'Actualizando...' : 'Actualizar historial'}</button>
    </div>
  </div>;
}

function HistoryPanel({ userId }: { userId: string }) {
  const [bets, setBets] = useState<LocalDerbyBet[]>([]);
  const [movements, setMovements] = useState<LocalLedgerMovement[]>([]);

  async function load() {
    setBets(await localDerbyHistory(userId));
    const all = await dbGetAll<LocalLedgerMovement>('ledger_movements');
    setMovements(all.filter(m => m.userId === userId).sort((a, b) => b.createdAt.localeCompare(a.createdAt)));
  }

  useEffect(() => {
    load();
    const t = setInterval(load, 3000);
    return () => clearInterval(t);
  }, [userId]);

  return <section className="glass history-card clean-history">
    <h2><History /> Historial de jugadas</h2>
    {bets.length === 0 ? <p>No hay boletos registrados.</p> : bets.map(b => <div className="history-row" key={b.id}>
      <strong>{b.raceCode}</strong>
      <span>Caballo #{b.selectedHorse}</span>
      <span>{coins(b.amount)} monedas</span>
      <span className={b.status === 'won' ? 'pos' : b.status === 'lost' ? 'neg' : ''}>{b.status === 'won' ? 'Ganó' : b.status === 'lost' ? 'Perdió' : 'Pendiente'}</span>
      <small>{new Date(b.createdAt).toLocaleString()}</small>
    </div>)}
    {movements.length > 0 && <small className="muted">Movimientos auditables internos: {movements.length}</small>}
  </section>;
}

export function App() {
  const [user, setUser] = useState<User | null>(null);
  const [localWallet, setLocalWallet] = useState<LocalWalletState | null>(null);
  const [syncCount, setSyncCount] = useState(0);
  const [tab, setTab] = useState<Tab>('games');
  const [loading, setLoading] = useState(true);

  async function refreshLocal(userId = user?.id) {
    if (!userId) return;
    const wallet = await getLocalWallet(userId);
    setLocalWallet(wallet);
    setSyncCount((await pendingSyncItems()).length);
  }

  async function bootstrap(u: User, w: Wallet) {
    setUser(u);
    const local = await initLocalWallet(u.id, {
      demoBalance: w.demoBalance,
      realBalance: w.realBalance,
      giftLocked: w.giftLocked,
    });
    setLocalWallet(local);
    setSyncCount((await pendingSyncItems()).length);
  }

  useEffect(() => {
    api.me().then(res => bootstrap(res.user, res.wallet)).catch(() => null).finally(() => setLoading(false));
  }, []);

  const pendingInfo = useMemo(() => syncCount > 0 ? `${syncCount} movimientos pendientes` : 'Todo actualizado', [syncCount]);

  if (loading) return <div className="loading"><Sparkles className="spin" /> Cargando juego...</div>;
  if (!user) return <Login onLogin={(u, w) => { bootstrap(u, w); }} />;

  return <div className="app-shell clean-player-shell">
    <header className="topbar glass clean-topbar">
      <div className="brand"><span className="brand-derby">DERBY</span><div><strong>Juega123 Derby</strong><small>{pendingInfo}</small></div></div>
      <nav>
        <button className={tab === 'games' ? 'active' : ''} onClick={() => setTab('games')}><Trophy size={17}/> Derby</button>
        <button className={tab === 'history' ? 'active' : ''} onClick={() => setTab('history')}><History size={17}/> Historial</button>
      </nav>
      <button className="ghost" onClick={() => { logout(); location.reload(); }}><LogOut size={18}/> Salir</button>
    </header>

    <main className="clean-main">
      {tab === 'games' && <DerbyGame user={user} wallet={localWallet} refreshLocal={() => refreshLocal(user.id)} />}
      {tab === 'history' && <HistoryPanel userId={user.id} />}
    </main>
  </div>;
}
