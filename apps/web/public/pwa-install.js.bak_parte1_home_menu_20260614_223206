(function () {
  let deferredPrompt = null;

  function isStandalone() {
    return window.matchMedia('(display-mode: standalone)').matches ||
      window.navigator.standalone === true;
  }

  function goHome() {
    document.body.classList.add('hipiplay-home-mode');
    document.body.classList.remove('hipiplay-race-mode');

    window.dispatchEvent(new CustomEvent('hipiplay-view-change', {
      detail: { view: 'home' }
    }));

    window.scrollTo({ top: 0, behavior: 'smooth' });
    updateControls();
  }

  function findHeader() {
    return document.querySelector('.player-header, .wallet-header, .app-header, header');
  }

  function ensureControls() {
    if (document.getElementById('hipiplay-header-actions')) {
      updateControls();
      return;
    }

    const header = findHeader();
    if (!header) return;

    const wrap = document.createElement('div');
    wrap.id = 'hipiplay-header-actions';

    const install = document.createElement('button');
    install.id = 'hipiplay-header-install-button';
    install.type = 'button';
    install.textContent = 'Instalar';

    const menu = document.createElement('button');
    menu.id = 'hipiplay-header-menu-button';
    menu.type = 'button';
    menu.textContent = 'Menú';

    wrap.appendChild(install);
    wrap.appendChild(menu);
    header.appendChild(wrap);

    install.addEventListener('click', async function () {
      if (isStandalone()) {
        install.style.display = 'none';
        return;
      }

      if (deferredPrompt) {
        deferredPrompt.prompt();
        await deferredPrompt.userChoice.catch(() => null);
        deferredPrompt = null;
        updateControls();
        return;
      }

      alert('Para instalar: abre el menú ⋮ de Chrome y toca “Agregar a pantalla de inicio”.');
    });

    menu.addEventListener('click', goHome);

    updateControls();
  }

  function updateControls() {
    const wrap = document.getElementById('hipiplay-header-actions');
    const install = document.getElementById('hipiplay-header-install-button');

    if (!wrap) return;

    if (document.body.classList.contains('hipiplay-race-mode')) {
      wrap.style.display = 'flex';
    } else {
      wrap.style.display = 'none';
    }

    if (install && isStandalone()) {
      install.style.display = 'none';
    }
  }

  function init() {
    if (!document.body.classList.contains('hipiplay-race-mode')) {
      document.body.classList.add('hipiplay-home-mode');
    }

    ensureControls();
    updateControls();

    window.addEventListener('hipiplay-view-change', updateControls);
    window.addEventListener('resize', updateControls);

    setTimeout(ensureControls, 500);
    setTimeout(ensureControls, 1500);
  }

  window.addEventListener('beforeinstallprompt', function (event) {
    event.preventDefault();
    deferredPrompt = event;
    updateControls();
  });

  window.addEventListener('appinstalled', function () {
    deferredPrompt = null;
    updateControls();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();