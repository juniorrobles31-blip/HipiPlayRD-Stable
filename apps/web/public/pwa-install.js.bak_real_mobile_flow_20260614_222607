(function () {
  let deferredPrompt = null;

  const ACTIONS = [
    { action: 'transfer', label: 'Transferencia', icon: '↔' },
    { action: 'bet', label: 'Apuesta', icon: '🏆' },
    { action: 'withdraw', label: 'Retiro USDT', icon: '🏦' },
    { action: 'deposit', label: 'Recarga USDT', icon: '👛' },
    { action: 'sell-p2p', label: 'Venta P2P', icon: '🤝' },
    { action: 'buy-p2p', label: 'Compra P2P', icon: '🛒' }
  ];

  function isStandalone() {
    return window.matchMedia('(display-mode: standalone)').matches ||
      window.navigator.standalone === true;
  }

  function createTopBar() {
    if (document.getElementById('hipiplay-mobile-top-actions')) return;

    const bar = document.createElement('div');
    bar.id = 'hipiplay-mobile-top-actions';
    bar.innerHTML = `
      <button id="hipiplay-pwa-install-button" type="button">⬇ Instalar</button>
      <button id="hipiplay-mobile-menu-button" type="button">☰ Menú</button>
    `;

    document.body.appendChild(bar);

    const installBtn = document.getElementById('hipiplay-pwa-install-button');
    const menuBtn = document.getElementById('hipiplay-mobile-menu-button');

    installBtn.addEventListener('click', async function () {
      if (isStandalone()) {
        showToast('La app ya está instalada.');
        return;
      }

      if (deferredPrompt) {
        deferredPrompt.prompt();
        await deferredPrompt.userChoice.catch(() => null);
        deferredPrompt = null;
        return;
      }

      showToast('Para instalar: abre el menú ⋮ de Chrome y toca “Agregar a pantalla de inicio”.');
    });

    menuBtn.addEventListener('click', openMenu);
  }

  function createMenu() {
    if (document.getElementById('hipiplay-mobile-menu-overlay')) return;

    const overlay = document.createElement('div');
    overlay.id = 'hipiplay-mobile-menu-overlay';

    overlay.innerHTML = `
      <div class="hipiplay-mobile-menu-card">
        <div class="hipiplay-mobile-menu-head">
          <strong>HipiPlay</strong>
          <button id="hipiplay-mobile-menu-close" type="button">×</button>
        </div>

        <div class="hipiplay-mobile-menu-grid">
          ${ACTIONS.map(item => `
            <button type="button" data-hipiplay-action="${item.action}">
              <span class="hipiplay-menu-icon">${item.icon}</span>
              <span>${item.label}</span>
            </button>
          `).join('')}
        </div>
      </div>
    `;

    document.body.appendChild(overlay);

    overlay.addEventListener('click', function (event) {
      if (event.target === overlay) closeMenu();
    });

    document.getElementById('hipiplay-mobile-menu-close').addEventListener('click', closeMenu);

    overlay.querySelectorAll('[data-hipiplay-action]').forEach(button => {
      button.addEventListener('click', function () {
        const action = button.getAttribute('data-hipiplay-action');

        closeMenu();

        if (action === 'bet') {
          const target = document.querySelector('.horse-grid, .horses-grid, .race-horses-grid, .horse-select-grid, .race-panel, .race-card');
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }

        window.dispatchEvent(new CustomEvent('hipiplay-wallet-action', {
          detail: { action }
        }));
      });
    });
  }

  function openMenu() {
    createMenu();
    document.body.classList.add('hipiplay-menu-open');
  }

  function closeMenu() {
    document.body.classList.remove('hipiplay-menu-open');
  }

  function showToast(message) {
    let toast = document.getElementById('hipiplay-mobile-toast');

    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'hipiplay-mobile-toast';
      document.body.appendChild(toast);
    }

    toast.textContent = message;
    toast.classList.add('show');

    clearTimeout(window.__hipiplayToastTimer);
    window.__hipiplayToastTimer = setTimeout(() => {
      toast.classList.remove('show');
    }, 3600);
  }

  function injectStyles() {
    if (document.getElementById('hipiplay-mobile-top-actions-style')) return;

    const style = document.createElement('style');
    style.id = 'hipiplay-mobile-top-actions-style';

    style.textContent = `
      #hipiplay-mobile-top-actions {
        position: fixed;
        top: 14px;
        right: 12px;
        z-index: 999999;
        display: flex;
        gap: 8px;
        align-items: center;
        pointer-events: auto;
      }

      #hipiplay-mobile-top-actions button {
        border: 1px solid rgba(255, 213, 77, .45);
        border-radius: 999px;
        padding: 9px 12px;
        font-size: 13px;
        font-weight: 900;
        color: #fff;
        background: rgba(4, 24, 16, .92);
        box-shadow: 0 10px 26px rgba(0,0,0,.35);
        backdrop-filter: blur(14px);
      }

      #hipiplay-pwa-install-button {
        background: linear-gradient(135deg, #20b84b, #74e600) !important;
        color: #07160b !important;
      }

      #hipiplay-mobile-menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 999998;
        display: none;
        align-items: flex-end;
        justify-content: center;
        padding: 18px;
        background: rgba(0, 0, 0, .62);
        backdrop-filter: blur(10px);
      }

      body.hipiplay-menu-open #hipiplay-mobile-menu-overlay {
        display: flex;
      }

      .hipiplay-mobile-menu-card {
        width: 100%;
        max-width: 430px;
        border-radius: 30px;
        padding: 18px;
        background:
          radial-gradient(circle at top left, rgba(69, 214, 91, .18), transparent 42%),
          linear-gradient(180deg, rgba(8, 30, 22, .98), rgba(3, 18, 12, .98));
        border: 1px solid rgba(229, 184, 75, .34);
        box-shadow: 0 24px 70px rgba(0,0,0,.58);
      }

      .hipiplay-mobile-menu-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        color: #fff;
        font-size: 22px;
      }

      #hipiplay-mobile-menu-close {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,.16);
        color: #fff;
        background: rgba(255,255,255,.08);
        font-size: 30px;
        line-height: 1;
      }

      .hipiplay-mobile-menu-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .hipiplay-mobile-menu-grid button {
        min-height: 104px;
        border-radius: 22px;
        border: 1px solid rgba(229, 184, 75, .28);
        background:
          radial-gradient(circle at top left, rgba(70, 214, 84, .18), transparent 46%),
          linear-gradient(180deg, rgba(255,255,255,.075), rgba(255,255,255,.025));
        color: #fff;
        font-size: 16px;
        font-weight: 900;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 9px;
      }

      .hipiplay-menu-icon {
        font-size: 30px;
        line-height: 1;
      }

      #hipiplay-mobile-toast {
        position: fixed;
        left: 50%;
        bottom: 120px;
        transform: translateX(-50%) translateY(20px);
        z-index: 1000000;
        width: calc(100% - 34px);
        max-width: 410px;
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(5, 20, 14, .96);
        border: 1px solid rgba(229, 184, 75, .38);
        color: #fff;
        font-size: 14px;
        font-weight: 800;
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s ease, transform .2s ease;
        box-shadow: 0 16px 40px rgba(0,0,0,.42);
      }

      #hipiplay-mobile-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      @media (min-width: 821px) {
        #hipiplay-mobile-top-actions {
          top: 18px;
          right: 18px;
        }
      }
    `;

    document.head.appendChild(style);
  }

  function init() {
    injectStyles();
    createTopBar();
    createMenu();

    if (isStandalone()) {
      const installBtn = document.getElementById('hipiplay-pwa-install-button');
      if (installBtn) installBtn.style.display = 'none';
    }
  }

  window.addEventListener('beforeinstallprompt', function (event) {
    event.preventDefault();
    deferredPrompt = event;

    const installBtn = document.getElementById('hipiplay-pwa-install-button');
    if (installBtn && !isStandalone()) {
      installBtn.style.display = 'inline-flex';
    }
  });

  window.addEventListener('appinstalled', function () {
    deferredPrompt = null;
    const installBtn = document.getElementById('hipiplay-pwa-install-button');
    if (installBtn) installBtn.style.display = 'none';
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();