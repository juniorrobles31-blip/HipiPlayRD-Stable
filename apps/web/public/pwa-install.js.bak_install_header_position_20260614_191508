(function () {
  const BUTTON_ID = 'hipiplay-pwa-install-button';
  const INSTALL_FLAG = 'hipiplay_pwa_installed_v1';

  let deferredPrompt = null;
  let installedDuringSession = false;

  function isStandaloneMode() {
    return Boolean(
      (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) ||
      (window.matchMedia && window.matchMedia('(display-mode: fullscreen)').matches) ||
      (window.matchMedia && window.matchMedia('(display-mode: minimal-ui)').matches) ||
      (window.navigator && window.navigator.standalone === true) ||
      (document.referrer && document.referrer.startsWith('android-app://'))
    );
  }

  function wasInstalledBefore() {
    try {
      return localStorage.getItem(INSTALL_FLAG) === '1';
    } catch (error) {
      return false;
    }
  }

  function markInstalled() {
    installedDuringSession = true;

    try {
      localStorage.setItem(INSTALL_FLAG, '1');
    } catch (error) {}

    document.documentElement.classList.add('pwa-installed');

    if (document.body) {
      document.body.classList.add('pwa-installed');
    }
  }

  function shouldHideInstall() {
    if (installedDuringSession) return true;
    if (isStandaloneMode()) return true;
    if (wasInstalledBefore()) return true;
    if (!deferredPrompt) return true;
    if (!document.body) return true;
    if (document.body.classList.contains('hipi-wallet-home-open')) return true;
    if (document.body.classList.contains('hipi-hide-header-menu')) return true;

    return false;
  }

  function hideButton() {
    const button = document.getElementById(BUTTON_ID);

    if (button) {
      button.style.display = 'none';
      button.setAttribute('aria-hidden', 'true');
    }
  }

  function findHeader() {
    const headers = Array.from(
      document.querySelectorAll('header, .app-header, .topbar, [class*="header"], [class*="topbar"], [class*="brand"]')
    );

    const byText = headers.find(function (el) {
      const text = (el.textContent || '').toLowerCase();
      return text.includes('hipiplay');
    });

    if (byText) {
      return byText.closest('header') || byText;
    }

    return document.querySelector('header');
  }

  function createButton() {
    let button = document.getElementById(BUTTON_ID);

    if (button) return button;

    button = document.createElement('button');
    button.id = BUTTON_ID;
    button.type = 'button';
    button.className = 'wallet-header-install-button';
    button.innerHTML = '<span class="wallet-header-install-icon">⬇</span><span>Instalar</span>';

    button.addEventListener('click', async function () {
      if (!deferredPrompt) {
        hideButton();
        return;
      }

      button.disabled = true;

      try {
        deferredPrompt.prompt();

        const choice = await deferredPrompt.userChoice.catch(function () {
          return { outcome: 'dismissed' };
        });

        deferredPrompt = null;

        if (choice && choice.outcome === 'accepted') {
          markInstalled();
        }

        hideButton();
      } catch (error) {
        button.disabled = false;
        hideButton();
      }
    });

    return button;
  }

  function placeButton() {
    if (shouldHideInstall()) {
      hideButton();
      return false;
    }

    const header = findHeader();

    if (!header) {
      hideButton();
      return false;
    }

    header.classList.add('hipiplay-header-menu-target');

    const button = createButton();
    const menuButton = document.getElementById('hipiplay-header-wallet-menu-button');

    if (menuButton && menuButton.parentElement === header) {
      if (button.parentElement !== header || button.nextSibling !== menuButton) {
        header.insertBefore(button, menuButton);
      }
    } else if (button.parentElement !== header) {
      header.appendChild(button);
    }

    if (shouldHideInstall()) {
      hideButton();
      return false;
    }

    button.style.display = 'inline-flex';
    button.setAttribute('aria-hidden', 'false');
    button.disabled = false;

    return true;
  }

  function placeButtonWithLimitedRetries() {
    let attempts = 0;
    const maxAttempts = 8;

    function tryOnce() {
      attempts += 1;

      const placed = placeButton();

      if (!placed && attempts < maxAttempts && deferredPrompt) {
        window.setTimeout(tryOnce, 500);
      }
    }

    tryOnce();
  }

  window.addEventListener('beforeinstallprompt', function (event) {
    event.preventDefault();
    deferredPrompt = event;
    placeButtonWithLimitedRetries();
  });

  window.addEventListener('appinstalled', function () {
    deferredPrompt = null;
    markInstalled();
    hideButton();
  });

  document.addEventListener('DOMContentLoaded', function () {
    if (isStandaloneMode()) {
      markInstalled();
      hideButton();
      return;
    }

    placeButtonWithLimitedRetries();
  });

  window.addEventListener('load', function () {
    if (isStandaloneMode()) {
      markInstalled();
      hideButton();
      return;
    }

    placeButtonWithLimitedRetries();
  });

  document.addEventListener('click', function (event) {
    const target = event.target;
    const button = target && target.closest ? target.closest('button') : null;

    if (!button) return;

    const text = (button.textContent || '').trim().toLowerCase();

    if (text === 'apostar' || text.includes('confirmar apuesta') || text.includes('realizar apuesta')) {
      hideButton();
    }
  }, true);
})();